# Database (PostgreSQL)
DATABASE_URL=postgresql://starium:starium@localhost:5432/starium

# API (apps/api)
PORT=3001

# Auth (JWT) — obligatoire pour le module auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# MFA — clé AES-256 (64 caractères hex = 32 octets) ; recommandé en production
# MFA_ENCRYPTION_KEY=0123456789abcdef0123456789abcdef0123456789abcdef0123456789abcdef

# Stockage fichiers API (avatars, etc.) — défaut : apps/api/uploads depuis la cwd du process
# UPLOAD_DIR=/var/lib/starium/uploads

# OTP email (fallback 2FA) — optionnel : sans SMTP, le code est loggé côté API
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Web (apps/web) — URL de l’API pour le client
NEXT_PUBLIC_API_URL=http://localhost:3001

# Docker Compose (publier Postgres / API sur d’autres ports si conflit sur l’hôte)
# POSTGRES_PUBLISH_PORT=5433
# API_PUBLISH_PORT=3002
