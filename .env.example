# Database (PostgreSQL)
DATABASE_URL=postgresql://starium:starium@localhost:5432/starium

# API (apps/api)
PORT=3001
# Origines autorisées pour le navigateur quand le front et l’API ne partagent pas le même host (production).
# Développement : CORS large activé automatiquement (pas besoin de cette variable).
# Ex. : CORS_ORIGINS=https://app.example.com,https://www.example.com
# CORS_ORIGINS=
# Seuil minimal de score matching chatbot (0–1000), défaut applicatif 50 si absent (RFC-AI-001).
# CHATBOT_MATCH_MIN_SCORE=50
# Limite ligne de requête / en-têtes (octets) — OAuth Microsoft peut envoyer un ?code= très long (défaut Node 16 Ko insuffisant).
# HTTP_MAX_HEADER_SIZE_BYTES=262144

# Auth (JWT) — obligatoire pour le module auth
JWT_SECRET=change-me-in-production-min-32-chars
JWT_ACCESS_EXPIRATION=900
JWT_REFRESH_EXPIRATION=604800

# MFA — clé AES-256 : 32 octets en hex (64 caractères). Générer avec : openssl rand -hex 32
# MFA_ENCRYPTION_KEY=

# Stockage fichiers API (avatars, etc.) — défaut : apps/api/uploads depuis la cwd du process
# UPLOAD_DIR=/var/lib/starium/uploads

# OTP email (fallback 2FA)
# — Dev hors Docker : sans SMTP_HOST, le code est loggé côté API (sauf NODE_ENV=production).
# — Dev Docker (`docker-compose.dev.yml`) : MailHog est déjà câblé (SMTP_HOST=mailhog dans le compose) ; UI http://localhost:8025
# — Prod : SMTP_HOST obligatoire pour tout envoi réel.
# SMTP_HOST=localhost
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM=noreply@example.com

# Web (apps/web) — URL de l’API pour le client navigateur.
# Vide = requêtes same-origin /api/… (rewrites Next → API, pas de CORS à configurer).
# http://localhost:3001 = appels directs vers Nest (dev : CORS activé côté API hors production).
NEXT_PUBLIC_API_URL=http://localhost:3001
# Optionnel (web) : origine API pour la redirection navigateur du callback SSO ; si NEXT_PUBLIC_API_URL pointe par erreur vers un host Docker (api-dev), le callback SSO utilise localhost:3001 par défaut.
# NEXT_PUBLIC_SSO_CALLBACK_API_URL=http://localhost:3001

# Microsoft 365 / Graph (OAuth délégué) — apps/api
# Enregistrer la même redirect URI dans l’app Azure AD (ex. http://localhost:3001/api/microsoft/auth/callback)
# MICROSOFT_CLIENT_ID=
# MICROSOFT_CLIENT_SECRET=
# SSO utilisateur (login Microsoft) : si ID/secret ne sont pas en variables d’environnement, les enregistrer dans Administration plateforme → Microsoft 365 — plateforme (ID app Entra + secret + tenant).
# Scopes SSO : OIDC seulement par défaut (openid profile email) — pas les scopes Graph plateforme. Ajouter User.Read ici si besoin du fallback Graph /me.
# MICROSOFT_SSO_SCOPES=openid profile email
# Comportement écran Microsoft : select_account (défaut), login, consent, none — voir docs Entra OAuth2.
# MICROSOFT_SSO_PROMPT=select_account
# MICROSOFT_REDIRECT_URI=http://localhost:3001/api/microsoft/auth/callback
# Tenant : common | organizations | <tenant-guid>
# MICROSOFT_TENANT=common
# Scopes Graph (espaces) — défaut raisonnable si absent
# MICROSOFT_GRAPH_SCOPES=offline_access openid profile email User.Read
# Redirections navigateur après callback OAuth (SPA) — de préférence la page Administration client → Microsoft 365
# MICROSOFT_OAUTH_SUCCESS_URL=http://localhost:3000/client/administration/microsoft-365?microsoft=connected
# MICROSOFT_OAUTH_ERROR_URL=http://localhost:3000/client/administration/microsoft-365?microsoft=error
# Chiffrement des jetons au repos (64 hex recommandé) — défaut : dérivation depuis JWT_SECRET
# MICROSOFT_TOKEN_ENCRYPTION_KEY=
# MICROSOFT_TOKEN_HTTP_TIMEOUT_MS=5000
# Timeout requêtes Microsoft Graph (ms) — défaut aligné sur le token HTTP
# MICROSOFT_GRAPH_HTTP_TIMEOUT_MS=5000
# MICROSOFT_REFRESH_LEEWAY_SECONDS=300
# MICROSOFT_OAUTH_STATE_TTL_SECONDS=600
# Store jti anti-replay : memory (défaut) — redis prévu pour multi-instance
# MICROSOFT_OAUTH_STATE_STORE=memory

# --- RFC — Vérification e-mail des identités secondaires (lien de confirmation) ---
# Redirections après consommation du token (clic dans l’e-mail).
EMAIL_IDENTITY_VERIFY_SUCCESS_URL=http://localhost:3000/account
EMAIL_IDENTITY_VERIFY_ERROR_URL=http://localhost:3000/account
# TTL du token de vérification (heures) — défaut : 24
EMAIL_IDENTITY_VERIFY_TOKEN_TTL_HOURS=24
# Cooldown anti-spam pour le renvoi (minutes) — défaut : 15. Mettre 0 pour tests manuels sans délai (hors production).
EMAIL_IDENTITY_VERIFY_RESEND_COOLDOWN_MINUTES=15
# Alternative sans modifier la valeur ci-dessus : bypass uniquement hors production (même effet que 0 minute).
# STARIUM_SKIP_EMAIL_IDENTITY_RESEND_COOLDOWN=1

# Redis (BullMQ — file d’attente emails RFC-038). Défaut API : 127.0.0.1:6379.
# Avec `docker compose -f docker-compose.dev.yml` : api-dev utilise REDIS_HOST=host.docker.internal (port 6379 du service redis publié sur l’hôte). En local (pnpm nest) : 127.0.0.1 ou lancer le service redis du compose.
# REDIS_HOST=127.0.0.1
# REDIS_PORT=6379
# REDIS_PASSWORD=

# E-mails mis en file par l’API (vérification identité, alertes critiques, etc.) :
# — développement : traitement immédiat dans le process API par défaut (pas besoin de `pnpm start:worker`).
# — production : file BullMQ + process `pnpm start:worker` obligatoire pour l’envoi réel.
# Forcer la file même en dev : EMAIL_DELIVERIES_INLINE=false
# Forcer l’inline même en prod (déconseillé) : EMAIL_DELIVERIES_INLINE=true
# EMAIL_DELIVERIES_INLINE=

# Docker Compose — le `.env` racine est lu pour l’interpolation `${VAR:-défaut}`.
#
# • Dev : `docker compose -f docker-compose.dev.yml` → service `api-dev` (voir commentaires dans ce fichier).
# • Prod-like : `docker compose -f docker-compose.yml` → services `api` / `web` (`x-api-base-env` : SMTP_*, EMAIL_IDENTITY_VERIFY_*, REDIS_*, JWT_*, MFA_*, etc.).
#   Vérifier ce qui est injecté : `docker compose -f docker-compose.yml config | less` puis `docker compose exec api sh -lc 'env | sort | grep -E \"^(SMTP_|EMAIL_|REDIS_)\"'`.
# Défauts compose dev : STARIUM_SKIP_EMAIL_IDENTITY_RESEND_COOLDOWN=1 (hors prod côté app). En prod Docker, ne pas définir STARIUM ou laisser vide.
# POSTGRES_PUBLISH_PORT=5433
# API_PUBLISH_PORT=3002

# --- RFC-035 — Procurement (fichiers commandes / factures / contrats) ---
# Source principale : Administration plateforme → stockage procurement (base). Activer la config en base,
# renseigner S3 + région (ex. eu-west-3) ; pas besoin de PROCUREMENT_S3_* ici pour un run normal.
# Variables ci-dessous = secours (CI, override Docker, secret admin indéchiffrable).
# PROCUREMENT_STORAGE_DRIVER : uniquement si aucune ligne plateforme (bootstrap/tests) ; sinon le driver suit l’admin.
# PROCUREMENT_STORAGE_DRIVER=local
# PROCUREMENT_LOCAL_ROOT=/data/procurement-blobs
# PROCUREMENT_S3_ENDPOINT=
# PROCUREMENT_S3_ACCESS_KEY=
# PROCUREMENT_S3_SECRET_KEY=
# PROCUREMENT_S3_BUCKET=
# PROCUREMENT_S3_REGION=eu-west-3
# PROCUREMENT_S3_USE_SSL=true
# PROCUREMENT_S3_FORCE_PATH_STYLE=false
# PROCUREMENT_CLIENT_DOCUMENTS_BUCKET_PREFIX=  # si le champ admin « préfixe buckets » est vide
