generator client {
  provider = "prisma-client-js"
}

// Seed: pnpm prisma:seed ou prisma db seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
}

enum ClientUserRole {
  CLIENT_ADMIN
  CLIENT_USER
}

enum ClientUserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

model HealthCheck {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
}

model Client {
  id                   String                @id @default(cuid())
  name                 String
  slug                 String                @unique
  createdAt            DateTime              @default(now())
  updatedAt            DateTime              @updatedAt
  clientUsers          ClientUser[]
  clientModules        ClientModule[]
  roles                Role[]
  auditLogs            AuditLog[]
  budgetExercises      BudgetExercise[]
  budgets              Budget[]
  budgetEnvelopes      BudgetEnvelope[]
  budgetLines          BudgetLine[]
  financialAllocations FinancialAllocation[]
  financialEvents      FinancialEvent[]
  budgetSnapshots       BudgetSnapshot[]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  platformRole  PlatformRole?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clientUsers   ClientUser[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  securityLogs  SecurityLog[]
  ownedBudgets Budget[]           @relation("OwnedBudgets")
  createdBudgetSnapshots BudgetSnapshot[]
}

model ClientUser {
  id        String           @id @default(cuid())
  userId    String
  clientId  String
  role      ClientUserRole
  status    ClientUserStatus @default(ACTIVE)
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
  @@index([userId])
}

/// Catalogue global des modules (budgets, projects, contracts, etc.).
model Module {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  permissions   Permission[]
  clientModules ClientModule[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Activation d'un module pour un client donné.
model ClientModule {
  id        String             @id @default(cuid())
  clientId  String
  moduleId  String
  status    ClientModuleStatus @default(ENABLED)
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([clientId, moduleId])
  @@index([clientId])
  @@index([moduleId])
}

/// Rôle métier client (scopé par client).
model Role {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  description    String?
  isSystem       Boolean         @default(false)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles      UserRole[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([clientId, name])
  @@index([clientId])
}

/// Permission unitaire globale (<module>.<action>).
model Permission {
  id             String          @id @default(cuid())
  code           String          @unique
  label          String
  description    String?
  moduleId       String
  module         Module          @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([moduleId])
}

/// Liaison N:N rôle ↔ permission.
model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

/// Liaison utilisateur ↔ rôle métier (le client est porté par Role.clientId).
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

enum ClientModuleStatus {
  ENABLED
  DISABLED
}

// --- Budget MVP (RFC-015-1A) ---

enum BudgetExerciseStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum BudgetEnvelopeType {
  RUN
  BUILD
  TRANSVERSE
}

enum BudgetLineStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum ExpenseType {
  OPEX
  CAPEX
}

enum FinancialSourceType {
  PROJECT
  ACTIVITY
  SUPPLIER
  CONTRACT
  LICENSE
  ORDER
  TEAM_ASSIGNMENT
  APPLICATION
  ASSET
  MANUAL
}

enum AllocationType {
  PLANNED
  RESERVED
  COMMITTED
  CONSUMED
  FORECAST
  REALLOCATED
  CANCELLED
}

enum FinancialEventType {
  LINE_CREATED
  BUDGET_INITIALIZED
  ALLOCATION_ADDED
  ALLOCATION_UPDATED
  COMMITMENT_REGISTERED
  CONSUMPTION_REGISTERED
  FORECAST_UPDATED
  REALLOCATION_DONE
  CANCELLATION
  ADJUSTMENT
}

model BudgetExercise {
  id        String               @id @default(cuid())
  clientId  String
  name      String
  code      String
  startDate DateTime
  endDate   DateTime
  status    BudgetExerciseStatus @default(DRAFT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgets   Budget[]
  budgetSnapshots BudgetSnapshot[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([status])
}

model Budget {
  id            String       @id @default(cuid())
  clientId      String
  exerciseId    String
  name          String
  code          String
  description   String?
  currency      String
  status        BudgetStatus @default(DRAFT)
  ownerUserId   String?
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise      BudgetExercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  owner         User?        @relation("OwnedBudgets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  envelopes     BudgetEnvelope[]
  budgetLines   BudgetLine[]
  budgetSnapshots BudgetSnapshot[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([exerciseId])
  @@index([status])
}

model BudgetEnvelope {
  id          String             @id @default(cuid())
  clientId    String
  budgetId    String
  parentId    String?
  name        String
  code        String
  type        BudgetEnvelopeType
  description String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget      Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent      BudgetEnvelope?    @relation("EnvelopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BudgetEnvelope[]   @relation("EnvelopeHierarchy")
  budgetLines BudgetLine[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([parentId])
}

model BudgetLine {
  id              String           @id @default(cuid())
  clientId        String
  budgetId        String
  envelopeId      String
  code            String
  name            String
  description     String?
  expenseType     ExpenseType
  status          BudgetLineStatus @default(DRAFT)
  currency        String
  initialAmount   Decimal          @db.Decimal(18, 2) @default(0)
  revisedAmount   Decimal          @db.Decimal(18, 2) @default(0)
  forecastAmount  Decimal          @db.Decimal(18, 2) @default(0)
  committedAmount Decimal          @db.Decimal(18, 2) @default(0)
  consumedAmount  Decimal          @db.Decimal(18, 2) @default(0)
  remainingAmount Decimal          @db.Decimal(18, 2) @default(0)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget          Budget           @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  envelope        BudgetEnvelope   @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  allocations     FinancialAllocation[]
  financialEvents FinancialEvent[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([envelopeId])
  @@index([status])
}

enum BudgetSnapshotStatus {
  ACTIVE
  ARCHIVED
}

model BudgetSnapshot {
  id                   String                @id @default(cuid())
  clientId             String
  budgetId             String
  exerciseId           String
  name                 String
  code                 String
  description          String?
  snapshotDate         DateTime
  status               BudgetSnapshotStatus   @default(ACTIVE)

  budgetName           String
  budgetCode           String?
  budgetCurrency       String
  budgetStatus         BudgetStatus

  totalInitialAmount   Decimal               @db.Decimal(18, 2)
  totalRevisedAmount   Decimal               @db.Decimal(18, 2)
  totalForecastAmount  Decimal               @db.Decimal(18, 2)
  totalCommittedAmount Decimal               @db.Decimal(18, 2)
  totalConsumedAmount  Decimal               @db.Decimal(18, 2)
  totalRemainingAmount Decimal               @db.Decimal(18, 2)

  createdByUserId      String?
  createdAt            DateTime              @default(now())

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budget                Budget                @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  exercise              BudgetExercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  createdByUser         User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                 BudgetSnapshotLine[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([exerciseId])
  @@index([snapshotDate])
  @@index([clientId, budgetId])
}

model BudgetSnapshotLine {
  id               String   @id @default(cuid())
  snapshotId       String
  clientId         String

  budgetLineId     String
  budgetId         String
  envelopeId       String?

  envelopeName     String?
  envelopeCode     String?
  envelopeType     BudgetEnvelopeType?

  lineCode         String
  lineName         String
  expenseType      ExpenseType
  currency         String
  lineStatus       BudgetLineStatus

  initialAmount    Decimal  @db.Decimal(18, 2)
  revisedAmount    Decimal  @db.Decimal(18, 2)
  forecastAmount   Decimal  @db.Decimal(18, 2)
  committedAmount  Decimal  @db.Decimal(18, 2)
  consumedAmount   Decimal  @db.Decimal(18, 2)
  remainingAmount  Decimal  @db.Decimal(18, 2)

  createdAt        DateTime @default(now())

  snapshot         BudgetSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([clientId])
  @@index([budgetLineId])
  @@index([budgetId])
  @@index([envelopeId])
}

model FinancialAllocation {
  id             String         @id @default(cuid())
  clientId       String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String
  allocationType AllocationType
  allocatedAmount Decimal       @db.Decimal(18, 2)
  currency      String
  effectiveDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([allocationType])
}

model FinancialEvent {
  id            String              @id @default(cuid())
  clientId      String
  budgetLineId String
  sourceType   FinancialSourceType
  sourceId     String?
  eventType    FinancialEventType
  amount       Decimal             @db.Decimal(18, 2)
  currency     String
  eventDate    DateTime
  label        String
  description  String?
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine   BudgetLine          @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([eventType])
  @@index([eventDate])
}

// --- End Budget MVP ---

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditLog {
  id String @id @default(cuid())

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AuditLogArchive {
  id String @id

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType])
}

model SecurityLog {
  id String @id @default(cuid())

  event String

  userId String?
  email  String?

  success Boolean
  reason  String?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}
