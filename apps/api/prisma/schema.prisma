  label                  String
  amountHt               Decimal                 @db.Decimal(18, 2)
  taxRate                Decimal?                @db.Decimal(5, 2)
  taxAmount              Decimal?                @db.Decimal(18, 2)
  amountTtc              Decimal?                @db.Decimal(18, 2)
  invoiceDate            DateTime
  status                 InvoiceStatus           @default(VALIDATED)
