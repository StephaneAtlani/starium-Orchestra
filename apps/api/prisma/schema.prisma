generator client {
  provider = "prisma-client-js"
}

// Seed: pnpm prisma:seed ou prisma db seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
}

enum ClientUserRole {
  CLIENT_ADMIN
  CLIENT_USER
}

enum ClientUserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum ClientUserLicenseType {
  READ_ONLY
  READ_WRITE
}

enum ClientUserLicenseBillingMode {
  CLIENT_BILLABLE
  EXTERNAL_BILLABLE
  NON_BILLABLE
  PLATFORM_INTERNAL
  EVALUATION
}

enum ClientSubscriptionStatus {
  DRAFT
  ACTIVE
  SUSPENDED
  CANCELED
  EXPIRED
}

enum SubscriptionBillingPeriod {
  MONTHLY
  YEARLY
}

enum RoleScope {
  CLIENT
  GLOBAL
}

/// Challenge MFA (login ou enrollment) — identifiant public = `id` (challengeId).
enum MfaChallengePurpose {
  LOGIN
  ENROLL
}

/// Canal principal du challenge (fallback email stocke le hash OTP dans `otpCodeHash`).
enum MfaChallengeChannel {
  TOTP
  EMAIL
}

enum TaxDisplayMode {
  HT
  TTC
}

enum TaxInputMode {
  HT
  TTC
}

enum BudgetTaxMode {
  HT
  TTC
}

/// Onglet par défaut du pilotage budget (cockpit / fiche budget RFC-024).
enum BudgetCockpitDefaultPilotageMode {
  DASHBOARD
  SYNTHESE
  PREVISIONNEL
  ATTERRISSAGE
  FORECAST
}

enum MicrosoftConnectionStatus {
  ACTIVE
  EXPIRED
  REVOKED
  ERROR
}

enum MicrosoftAuthMode {
  DELEGATED
}

enum MicrosoftSyncStatus {
  PENDING
  SYNCED
  ERROR
}

enum DirectoryProviderType {
  MICROSOFT_GRAPH
  LDAP
}

enum DirectorySyncJobStatus {
  RUNNING
  COMPLETED
  FAILED
}

enum DirectorySyncMode {
  FULL
  GROUP_FILTERED
}

enum CollaboratorStatus {
  ACTIVE
  INACTIVE
  DISABLED_SYNC
}

enum CollaboratorSource {
  MANUAL
  DIRECTORY_SYNC
}

enum ExternalDirectoryType {
  MICROSOFT_GRAPH
  LDAP
}

enum SkillStatus {
  ACTIVE
  DRAFT
  ARCHIVED
}

enum SkillReferenceLevel {
  BEGINNER
  INTERMEDIATE
  ADVANCED
  EXPERT
}

enum CollaboratorSkillSource {
  SELF_DECLARED
  MANAGER_ASSESSED
  HR_REVIEW
  IMPORTED
  OTHER
}

enum WorkTeamStatus {
  ACTIVE
  ARCHIVED
}

enum WorkTeamMemberRole {
  MEMBER
  LEAD
  DEPUTY
}

/// RFC-TEAM-020 / TEAM-009 — saisie temps réalisé (workflow).
enum TimeEntryStatus {
  DRAFT
  SUBMITTED
  VALIDATED
  REJECTED
}

/// Verrouillage mensuel des saisies de temps (validation collaborateur / déverrouillage manager).
enum TimesheetMonthStatus {
  OPEN
  SUBMITTED
}

enum ManagerScopeMode {
  DIRECT_REPORTS_ONLY
  TEAM_SUBTREE
  HYBRID
}

/// RFC-TEAM-006 — axe sémantique stable (reporting). Non extensible côté données.
enum ActivityTaxonomyKind {
  PROJECT
  RUN
  SUPPORT
  TRANSVERSE
  OTHER
}

enum AlertSeverity {
  INFO
  WARNING
  CRITICAL
}

enum AlertStatus {
  ACTIVE
  RESOLVED
  DISMISSED
}

enum AlertType {
  BUDGET
  PROJECT
  STRATEGIC_VISION
  SYSTEM
  GENERIC
}

enum NotificationType {
  ALERT
  SYSTEM
  INFO
}

enum NotificationStatus {
  UNREAD
  READ
}

enum EmailDeliveryStatus {
  PENDING
  SENT
  FAILED
  RETRYING
}

model HealthCheck {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
}

model Client {
  id                               String                            @id @default(cuid())
  name                             String
  slug                             String                            @unique
  createdAt                        DateTime                          @default(now())
  updatedAt                        DateTime                          @updatedAt
  budgetAccountingEnabled          Boolean                           @default(false)
  taxDisplayMode                   TaxDisplayMode                    @default(HT)
  taxInputMode                     TaxInputMode                      @default(HT)
  defaultTaxRate                   Decimal?                          @db.Decimal(5, 2)
  clientUsers                      ClientUser[]
  clientSubscriptions              ClientSubscription[]
  clientModules                    ClientModule[]
  roles                            Role[]
  auditLogs                        AuditLog[]
  budgetExercises                  BudgetExercise[]
  budgets                          Budget[]
  budgetEnvelopes                  BudgetEnvelope[]
  budgetLines                      BudgetLine[]
  financialAllocations             FinancialAllocation[]
  financialEvents                  FinancialEvent[]
  suppliers                        Supplier[]
  supplierContacts                 SupplierContact[]
  supplierCategories               SupplierCategory[]
  purchaseOrders                   PurchaseOrder[]
  invoices                         Invoice[]
  supplierContracts                SupplierContract[]
  contractAttachments              ContractAttachment[]
  budgetSnapshots                  BudgetSnapshot[]
  budgetSnapshotOccasionTypes      BudgetSnapshotOccasionType[]
  supplierContractKindTypes        SupplierContractKindType[]
  budgetReallocations              BudgetReallocation[]
  budgetImportMappings             BudgetImportMapping[]
  budgetImportJobs                 BudgetImportJob[]
  budgetImportRowLinks             BudgetImportRowLink[]
  budgetVersionSets                BudgetVersionSet[]
  generalLedgerAccounts            GeneralLedgerAccount[]
  analyticalLedgerAccounts         AnalyticalLedgerAccount[]
  costCenters                      CostCenter[]
  budgetLineCostCenterSplits       BudgetLineCostCenterSplit[]
  projects                         Project[]
  projectScenarios                 ProjectScenario[]
  projectScenarioFinancialLines    ProjectScenarioFinancialLine[]
  projectScenarioResourcePlans     ProjectScenarioResourcePlan[]
  projectScenarioCapacitySnapshots ProjectScenarioCapacitySnapshot[]
  projectTasks                     ProjectTask[]
  projectRisks                     ProjectRisk[]
  projectMilestones                ProjectMilestone[]
  projectBudgetLinks               ProjectBudgetLink[]
  projectTeamRoles                 ProjectTeamRole[]
  projectTeamMembers               ProjectTeamMember[]
  projectSheetDecisionSnapshots    ProjectSheetDecisionSnapshot[]
  projectReviews                   ProjectReview[]
  projectReviewParticipants        ProjectReviewParticipant[]
  projectReviewDecisions           ProjectReviewDecision[]
  projectReviewActionItems         ProjectReviewActionItem[]
  projectActivities                ProjectActivity[]
  projectTags                      ProjectTag[]
  projectTagAssignments            ProjectTagAssignment[]
  strategicVisions                 StrategicVision[]
  strategicAxes                    StrategicAxis[]
  strategicDirections              StrategicDirection[]
  strategicDirectionStrategies     StrategicDirectionStrategy[]
  strategicDirectionStrategyAxisLinks StrategicDirectionStrategyAxisLink[]
  strategicDirectionStrategyObjectiveLinks StrategicDirectionStrategyObjectiveLink[]
  strategicObjectives              StrategicObjective[]
  strategicLinks                   StrategicLink[]
  projectPortfolioCategories       ProjectPortfolioCategory[]
  actionPlans                      ActionPlan[]
  budgetLinePlanningMonths         BudgetLinePlanningMonth[]
  budgetLinePlanningScenarios      BudgetLinePlanningScenario[]
  resourceRoles                    ResourceRole[]
  resources                        Resource[]
  microsoftConnections             MicrosoftConnection[]
  projectMicrosoftLinks            ProjectMicrosoftLink[]
  projectTaskSyncs                 ProjectTaskMicrosoftSync[]
  projectDocumentMicrosoftSyncs    ProjectDocumentMicrosoftSync[]
  projectDocuments                 ProjectDocument[]
  projectTaskBuckets               ProjectTaskBucket[]
  projectTaskPhases                ProjectTaskPhase[]
  projectTaskChecklistItems        ProjectTaskChecklistItem[]
  projectTaskLabels                ProjectTaskLabel[]
  projectTaskLabelAssignments      ProjectTaskLabelAssignment[]
  projectMilestoneLabels           ProjectMilestoneLabel[]
  projectMilestoneLabelAssignments ProjectMilestoneLabelAssignment[]
  directoryConnections             DirectoryConnection[]
  directoryGroupScopes             DirectoryGroupScope[]
  directorySyncJobs                DirectorySyncJob[]
  collaborators                    Collaborator[]
  skillCategories                  SkillCategory[]
  skills                           Skill[]
  collaboratorSkills               CollaboratorSkill[]
  workTeams                        WorkTeam[]
  workTeamMemberships              WorkTeamMembership[]
  managerScopeConfigs              ManagerScopeConfig[]
  managerScopeRootTeams            ManagerScopeRootTeam[]
  complianceFrameworks             ComplianceFramework[]
  complianceStatuses               ComplianceStatus[]
  complianceEvidences              ComplianceEvidence[]
  riskDomains                      RiskDomain[]
  riskTypes                        RiskType[]
  budgetDashboardConfigs           BudgetDashboardConfig[]
  budgetDashboardWidgets           BudgetDashboardWidget[]
  budgetDashboardWidgetOverrides   BudgetDashboardWidgetOverride[]
  activityTypes                    ActivityType[]
  resourceTimeEntries              ResourceTimeEntry[]
  resourceTimesheetMonths          ResourceTimesheetMonth[]
  orgUnits                         OrgUnit[]
  orgGroups                        OrgGroup[]
  orgUnitMemberships               OrgUnitMembership[]
  orgGroupMemberships              OrgGroupMembership[]
  procurementAttachments           ProcurementAttachment[]
  alerts                           Alert[]
  notifications                    Notification[]
  emailDeliveries                  EmailDelivery[]
  chatbotCategories                ChatbotCategory[]
  chatbotKnowledgeEntries          ChatbotKnowledgeEntry[]
  chatbotConversations             ChatbotConversation[]
  chatbotMessages                  ChatbotMessage[]

  /// App Azure AD (BYO) — identifiants OAuth par client Starium ; secret chiffré au repos.
  microsoftOAuthClientId              String?
  microsoftOAuthClientSecretEncrypted String?
  /// Segment d’autorité (`common`, GUID tenant, `organizations`…). Défaut `common` si vide.
  microsoftOAuthAuthorityTenant       String?

  /// Surcharges libellés / tons des badges UI (tâches, priorités, entrées custom) — fusion côté app avec `badge-registry`.
  uiBadgeConfig Json?

  /// Temps réalisé : case « Sans week-ends » cochée par défaut sur la grille.
  timesheetIgnoreWeekendsDefault Boolean  @default(true)
  /// Temps réalisé : autoriser une fraction > 1 (plus d’une journée type) par cellule.
  timesheetAllowFractionAboveOne Boolean  @default(false)
  /// Durée d’une journée type (h) pour conversion fraction → heures ; null = défaut applicatif 7,5 h.
  timesheetDayReferenceHours     Decimal? @db.Decimal(5, 2)

  /// Onglet pilotage budget affiché par défaut (mode global cockpit / préférence client).
  budgetCockpitDefaultPilotageMode BudgetCockpitDefaultPilotageMode @default(SYNTHESE)

  /// Overrides workflow budget (JSON sparse, contrat métier côté code — merge avec défauts applicatifs).
  budgetWorkflowConfig Json?

  /// Mode S3 : nom du **bucket dédié** à ce client (dérivé du préfixe plateforme + slug) ; clés = Commandes|Factures|Contrats/…
  documentsBucketName          String?
  documentsBucketProvisionedAt DateTime?

  projectScenarioTasks ProjectScenarioTask[]
  projectScenarioRisks ProjectScenarioRisk[]
  accessGroups               AccessGroup[]
  accessGroupMembers         AccessGroupMember[]
  clientModuleVisibilities   ClientModuleVisibility[]
  resourceAcls               ResourceAcl[]
  resourceAccessPolicies     ResourceAccessPolicy[]
  /// RFC-ACL-022 — feature flags scopés client (bascule moteur accès V2, etc.).
  featureFlags               ClientFeatureFlag[]
  /// RFC-ORG-004 — politique obligation ownership (mode par client).
  orgOwnershipPolicy         ClientOrgOwnershipPolicy?
}

/// RFC-ORG-004 — durcissement progressif de l’obligation Direction propriétaire.
enum OrgOwnershipPolicyMode {
  ADVISORY
  REQUIRED_ON_CREATE
  REQUIRED_ON_ACTIVATE
}

model ClientOrgOwnershipPolicy {
  clientId  String                 @id
  mode      OrgOwnershipPolicyMode @default(ADVISORY)
  updatedAt DateTime               @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
}

/// RFC-ACL-022 — bascule par client / par clé pour les features sensibles (par défaut désactivées).
model ClientFeatureFlag {
  id        String   @id @default(cuid())
  clientId  String
  flagKey   String
  enabled   Boolean
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, flagKey])
  @@index([clientId])
}

/// Défauts globaux badges UI (id = `default`) — fusionnés avant `Client.uiBadgeConfig`.
model PlatformUiBadgeSettings {
  id          String   @id @default("default")
  badgeConfig Json?
  updatedAt   DateTime @updatedAt
}

/// Paramètres OAuth Microsoft **plateforme** (une ligne, id = `default`) — redirect URI, scopes, timeouts.
/// Fusion avec variables d’environnement : la DB prime si la valeur est renseignée.
model PlatformMicrosoftSettings {
  id                            String   @id @default("default")
  redirectUri                   String?
  graphScopes                   String?
  oauthSuccessUrl               String?
  oauthErrorUrl                 String?
  oauthStateTtlSeconds          Int?
  refreshLeewaySeconds          Int?
  tokenHttpTimeoutMs            Int?
  /// Application Entra pour le SSO utilisateur (login). Secret chiffré au repos (même mécanisme que les autres secrets Microsoft).
  ssoOAuthClientId              String?
  ssoOAuthClientSecretEncrypted String?
  /// Segment d’autorité OAuth SSO (`common`, GUID tenant, …). Défaut `common` si vide.
  ssoOAuthAuthorityTenant       String?
  updatedAt                     DateTime @updatedAt
}

enum ProcurementStorageDriver {
  LOCAL
  S3
}

/// Connexion stockage procurement — singleton id = `default` (RFC-034, RFC-035 : local + S3 optionnel).
/// Plafond taille des fichiers « métier » (imports budget, pièces jointes procurement) — singleton id = `default`.
model PlatformUploadSettings {
  id             String   @id @default("default")
  /// Taille max en octets (bornée par min plateforme et plafond absolu configurable).
  maxUploadBytes Int
  updatedAt      DateTime @updatedAt
}

model PlatformProcurementS3Settings {
  id                 String                   @id @default("default")
  /// Si false : fallback env uniquement ou stockage indisponible selon implémentation.
  enabled            Boolean                  @default(false)
  /// Préférence persistée ; le runtime suit ce champ (admin). `PROCUREMENT_STORAGE_DRIVER` : repli si aucune ligne.
  storageDriver      ProcurementStorageDriver @default(S3)
  /// Racine disque (DB) si `enabled` ; `PROCUREMENT_LOCAL_ROOT` (env) prime (RFC-035).
  localRoot          String?
  endpoint           String?
  region             String?
  accessKey          String?
  secretKeyEncrypted String?
  bucket             String?
  useSsl             Boolean                  @default(true)
  /// MinIO / S3 custom : souvent true. AWS public : false (défaut).
  forcePathStyle     Boolean                  @default(false)
  /// Préfixe du nom des buckets S3 **par client** (ex. `starium-dev_` → `starium-dev-{slug}` ; `_` → `-`, max 63 car. au total).
  clientDocumentsBucketPrefix String?
  updatedAt          DateTime                 @updatedAt
}

model User {
  id                                   String                          @id @default(cuid())
  email                                String                          @unique
  passwordHash                         String
  /// Si false : connexion email/mot de passe interdite (ex. après première connexion Microsoft SSO).
  passwordLoginEnabled                 Boolean                         @default(true)
  firstName                            String?
  lastName                             String?
  /// Service / département (profil modifiable par l’utilisateur)
  department                           String?
  /// Intitulé de poste
  jobTitle                             String?
  /// Société / employeur affiché
  company                              String?
  /// Bureau / localisation
  office                               String?
  /// MIME image (ex. image/jpeg) si une photo est enregistrée sur disque
  avatarMimeType                       String?
  platformRole                         PlatformRole?
  createdAt                            DateTime                        @default(now())
  updatedAt                            DateTime                        @updatedAt
  clientUsers                          ClientUser[]
  userRoles                            UserRole[]
  refreshTokens                        RefreshToken[]
  auditLogs                            AuditLog[]
  securityLogs                         SecurityLog[]
  userMfa                              UserMfa?
  mfaChallenges                        MfaChallenge[]
  trustedDevices                       TrustedDevice[]
  ownedBudgets                         Budget[]                        @relation("OwnedBudgets")
  createdBudgetSnapshots               BudgetSnapshot[]
  budgetReallocationsCreated           BudgetReallocation[]
  createdBudgetImportMappings          BudgetImportMapping[]
  createdBudgetImportJobs              BudgetImportJob[]
  sponsoredProjects                    Project[]                       @relation("ProjectSponsor")
  ownedProjects                        Project[]                       @relation("ProjectOwner")
  ownedProjectTasks                    ProjectTask[]                   @relation("ProjectTaskOwner")
  createdProjectTasks                  ProjectTask[]                   @relation("ProjectTaskCreatedBy")
  updatedProjectTasks                  ProjectTask[]                   @relation("ProjectTaskUpdatedBy")
  ownedProjectMilestones               ProjectMilestone[]              @relation("ProjectMilestoneOwner")
  createdProjectMilestones             ProjectMilestone[]              @relation("ProjectMilestoneCreatedBy")
  updatedProjectMilestones             ProjectMilestone[]              @relation("ProjectMilestoneUpdatedBy")
  ownedProjectActivities               ProjectActivity[]               @relation("ProjectActivityOwner")
  createdProjectActivities             ProjectActivity[]               @relation("ProjectActivityCreatedBy")
  updatedProjectActivities             ProjectActivity[]               @relation("ProjectActivityUpdatedBy")
  ownedProjectRisks                    ProjectRisk[]
  projectTeamMembers                   ProjectTeamMember[]
  createdProjectSheetDecisionSnapshots ProjectSheetDecisionSnapshot[]  @relation("ProjectSheetDecisionSnapshotCreatedBy")
  selectedProjectScenarios             ProjectScenario[]               @relation("ProjectScenarioSelectedBy")
  archivedProjectScenarios             ProjectScenario[]               @relation("ProjectScenarioArchivedBy")
  facilitatedProjectReviews            ProjectReview[]                 @relation("ProjectReviewFacilitator")
  finalizedProjectReviews              ProjectReview[]                 @relation("ProjectReviewFinalizedBy")
  projectReviewParticipants            ProjectReviewParticipant[]
  emailIdentities                      UserEmailIdentity[]
  emailIdentityVerificationTokens    EmailIdentityVerificationToken[] @relation("EmailIdentityTokenUser")
  microsoftConnectionsConnected        MicrosoftConnection[]           @relation("MicrosoftConnectedBy")
  uploadedProjectDocuments             ProjectDocument[]               @relation("ProjectDocumentUploadedBy")
  ownedActionPlans                     ActionPlan[]                    @relation("ActionPlanOwner")
  budgetDashboardWidgetOverrides       BudgetDashboardWidgetOverride[]
  validatedCollaboratorSkills          CollaboratorSkill[]             @relation("CollaboratorSkillValidator")
  /// Fiches collaborateur liées à ce compte plateforme sur un client (référentiel équipes / staffing).
  linkedCollaborators                  Collaborator[]                  @relation("CollaboratorLinkedUser")
  uploadedProcurementAttachments       ProcurementAttachment[]         @relation("ProcurementAttachmentUploadedBy")
  uploadedContractAttachments          ContractAttachment[]            @relation("ContractAttachmentUploadedBy")
  notifications                        Notification[]
  resolvedAlerts                       Alert[]                         @relation("AlertResolvedBy")
  dismissedAlerts                      Alert[]                         @relation("AlertDismissedBy")
  approvedStrategicDirectionStrategies StrategicDirectionStrategy[]    @relation("StrategicDirectionStrategyApprovedBy")
  ownedStrategicObjectives             StrategicObjective[]            @relation("StrategicObjectiveOwner")
  emailDeliveries                      EmailDelivery[]                 @relation("EmailDeliveryCreatedBy")
  chatbotKnowledgeEntriesCreated       ChatbotKnowledgeEntry[]         @relation("ChatbotEntryCreatedBy")
  chatbotKnowledgeEntriesUpdated       ChatbotKnowledgeEntry[]         @relation("ChatbotEntryUpdatedBy")
  platformAuditLogs                    PlatformAuditLog[]
  stariumFeedbackRepliesAuthored       PlatformStariumFeedbackReply[]  @relation("PlatformStariumFeedbackReplyAuthor")
  accessGroupMembers                   AccessGroupMember[]
}

/// Adresse e-mail déclarée par l’utilisateur (affichage / futur envoi). Une par user + email normalisé.
model UserEmailIdentity {
  id                 String       @id @default(cuid())
  userId             String
  user               User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  email              String
  emailNormalized    String
  displayName        String?
  replyToEmail       String?
  isVerified         Boolean      @default(false)
  isActive           Boolean      @default(true)
  /**
   * true si l’identité est pilotée par la synchro annuaire (AD DS / Graph), pas par l’utilisateur.
   */
  directoryManaged   Boolean      @default(false)
  createdAt          DateTime     @default(now())
  updatedAt          DateTime     @updatedAt
  clientUsersDefault ClientUser[] @relation("ClientUserDefaultEmail")
  verificationTokens EmailIdentityVerificationToken[] @relation("EmailIdentityTokenEmailIdentity")

  @@unique([userId, emailNormalized])
  @@index([userId])
}

/// Token de vérification pour une identité e-mail secondaire.
/// Contrainte: token stocké en hash uniquement (jamais exposé ni journalisé en clair).
model EmailIdentityVerificationToken {
  id              String             @id @default(cuid())
  userId          String
  user            User               @relation(fields: [userId], references: [id], onDelete: Cascade, name: "EmailIdentityTokenUser")
  emailIdentityId String
  emailIdentity  UserEmailIdentity @relation(fields: [emailIdentityId], references: [id], onDelete: Cascade, name: "EmailIdentityTokenEmailIdentity")

  tokenHash       String            @unique
  expiresAt       DateTime
  consumedAt      DateTime?
  createdAt       DateTime          @default(now())

  @@index([userId, createdAt])
  @@index([emailIdentityId, createdAt])
  @@index([emailIdentityId, expiresAt])
}

model ClientUser {
  id                         String             @id @default(cuid())
  userId                     String
  clientId                   String
  role                       ClientUserRole
  status                     ClientUserStatus   @default(ACTIVE)
  licenseType                ClientUserLicenseType @default(READ_ONLY)
  licenseBillingMode         ClientUserLicenseBillingMode @default(NON_BILLABLE)
  subscriptionId             String?
  licenseStartsAt            DateTime?
  licenseEndsAt              DateTime?
  licenseAssignmentReason    String?
  /// Si true : pas de fiche Humaine dans le catalogue ressources pour ce membre (masquage explicite).
  excludeFromResourceCatalog Boolean            @default(false)
  isDefault                  Boolean            @default(false)
  defaultEmailIdentityId     String?
  defaultEmailIdentity       UserEmailIdentity? @relation("ClientUserDefaultEmail", fields: [defaultEmailIdentityId], references: [id], onDelete: Restrict)
  /// RFC-ORG-002 — fiche catalogue Resource type HUMAN pour ce membre (même clientId).
  resourceId                 String?
  createdAt                  DateTime           @default(now())
  updatedAt                  DateTime           @updatedAt
  user                       User               @relation(fields: [userId], references: [id], onDelete: Cascade)
  client                     Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  subscription               ClientSubscription? @relation(fields: [subscriptionId], references: [id], onDelete: SetNull)
  humanResource              Resource?          @relation("ClientUserHumanResource", fields: [resourceId], references: [id], onDelete: SetNull)

  @@unique([userId, clientId])
  @@unique([resourceId])
  @@index([clientId])
  @@index([userId])
  @@index([defaultEmailIdentityId])
  @@index([clientId, subscriptionId])
  @@index([clientId, licenseType, licenseBillingMode])
  @@index([clientId, licenseEndsAt])
  @@index([clientId, resourceId])
}

/// RFC-ACL-003 — regroupement métier client-scopé (visibilité module / ACL futures).
model AccessGroup {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members   AccessGroupMember[]

  @@unique([clientId, name])
  @@index([clientId])
}

model AccessGroupMember {
  id        String      @id @default(cuid())
  groupId   String
  userId    String
  clientId  String
  createdAt DateTime    @default(now())
  group     AccessGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client      @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([groupId, userId])
  @@index([clientId, userId])
}

/// RFC-ACL-004 — visibilité fine des modules (CLIENT / GROUP / USER).
enum ModuleVisibilityScopeType {
  CLIENT
  GROUP
  USER
}

enum ModuleVisibilityState {
  VISIBLE
  HIDDEN
}

model ClientModuleVisibility {
  id         String                    @id @default(cuid())
  clientId   String
  moduleCode String
  scopeType  ModuleVisibilityScopeType
  scopeId    String?
  visibility ModuleVisibilityState
  createdAt  DateTime                  @default(now())
  updatedAt  DateTime                  @updatedAt
  client     Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, moduleCode])
  @@index([clientId, scopeType, scopeId])
}

/// RFC-ACL-005 — sujet d’une entrée ACL ressource.
enum ResourceAclSubjectType {
  USER
  GROUP
}

/// RFC-ACL-005 — niveau accordé sur la ressource (hiérarchie READ < WRITE < ADMIN).
enum ResourceAclPermission {
  READ
  WRITE
  ADMIN
}

/// RFC-ACL-005 — entrée de contrôle d’accès générique par ressource (complète le RBAC).
model ResourceAcl {
  id             String                   @id @default(cuid())
  clientId       String
  /// Code normalisé (uppercase), whitelist métier V1 côté application.
  resourceType   String
  resourceId     String
  subjectType    ResourceAclSubjectType
  subjectId      String
  permission     ResourceAclPermission
  createdAt      DateTime                 @default(now())
  updatedAt      DateTime                 @updatedAt
  client         Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, resourceType, resourceId, subjectType, subjectId])
  @@index([clientId, resourceType, resourceId])
}

/// RFC-ACL-017 — mode de gouvernance d’accès par ressource (DEFAULT / RESTRICTIVE / SHARING).
enum ResourceAccessPolicyMode {
  DEFAULT
  RESTRICTIVE
  SHARING
}

/// RFC-ACL-017 — politique d’accès stockée par triplet client / type / id ressource.
model ResourceAccessPolicy {
  id           String                   @id @default(cuid())
  clientId     String
  resourceType String
  resourceId   String
  mode         ResourceAccessPolicyMode
  createdAt    DateTime                 @default(now())
  updatedAt    DateTime                 @updatedAt
  client       Client                   @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([clientId, resourceType, resourceId])
  @@index([clientId, resourceType, resourceId])
}

model ClientSubscription {
  id                  String                    @id @default(cuid())
  clientId            String
  status              ClientSubscriptionStatus  @default(DRAFT)
  billingPeriod       SubscriptionBillingPeriod @default(MONTHLY)
  readWriteSeatsLimit Int
  startsAt            DateTime?
  endsAt              DateTime?
  graceEndsAt         DateTime?
  createdAt           DateTime                  @default(now())
  updatedAt           DateTime                  @updatedAt
  client              Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  clientUsers         ClientUser[]

  @@index([clientId])
  @@index([clientId, status])
}

/// Catalogue global des modules (budgets, projects, contracts, etc.).
model Module {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  permissions   Permission[]
  clientModules ClientModule[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Activation d'un module pour un client donné.
model ClientModule {
  id        String             @id @default(cuid())
  clientId  String
  moduleId  String
  status    ClientModuleStatus @default(ENABLED)
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([clientId, moduleId])
  @@index([clientId])
  @@index([moduleId])
}

/// Rôle métier client (scopé par client).
model Role {
  id              String           @id @default(cuid())
  clientId        String?
  scope           RoleScope        @default(CLIENT)
  name            String
  description     String?
  isSystem        Boolean          @default(false)
  client          Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles       UserRole[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@unique([clientId, name])
  @@index([scope])
  @@index([clientId])
  @@index([name])
}

/// Permission unitaire globale (<module>.<action>).
model Permission {
  id              String           @id @default(cuid())
  code            String           @unique
  label           String
  description     String?
  moduleId        String
  module          Module           @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  @@index([moduleId])
}

/// Liaison N:N rôle ↔ permission.
model RolePermission {
  id           String     @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

/// Liaison utilisateur ↔ rôle métier (le client est porté par Role.clientId).
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

enum ClientModuleStatus {
  ENABLED
  DISABLED
}

// --- Resources (RFC-RES-001) ---

enum ResourceType {
  HUMAN
  MATERIAL
  LICENSE
}

/// Portée ressource humaine (aligné équipe projet : interne / externe).
enum ResourceAffiliation {
  INTERNAL
  EXTERNAL
}

/// Rôle métier catalogue (humain) — distinct du RBAC `Role`.
model ResourceRole {
  id        String     @id @default(cuid())
  clientId  String
  name      String
  code      String?
  client    Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resources Resource[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt

  @@unique([clientId, name])
  @@index([clientId])
}

model Resource {
  id             String               @id @default(cuid())
  clientId       String
  name           String
  /// Réservé au type HUMAN (optionnel).
  firstName      String?
  code           String?
  type           ResourceType
  email          String?
  roleId         String?
  affiliation    ResourceAffiliation?
  /// Société / employeur — pertinent si portée EXTERNE (HUMAN).
  companyName    String?
  dailyRate      Decimal?             @db.Decimal(12, 2)
  metadata       Json?
  /// Champs RH (RFC-TEAM-020 — alignement catalogue Humain / module Équipes).
  jobTitle       String?
  department     String?
  phone          String?
  mobile         String?
  employeeNumber String?
  createdAt      DateTime             @default(now())
  updatedAt      DateTime             @updatedAt

  client                           Client                            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resourceRole                     ResourceRole?                     @relation(fields: [roleId], references: [id], onDelete: SetNull)
  /// Tâches projet / plan dont cette ressource humaine est responsable (MVP pilotage).
  responsibleForProjectTasks       ProjectTask[]                     @relation("ProjectTaskResponsibleResource")
  workTeamMemberships              WorkTeamMembership[]
  ledWorkTeams                     WorkTeam[]                        @relation("WorkTeamLeadResource")
  managerScopeConfig               ManagerScopeConfig?
  projectScenarioResourcePlans     ProjectScenarioResourcePlan[]
  projectScenarioCapacitySnapshots ProjectScenarioCapacitySnapshot[]
  resourceTimeEntries              ResourceTimeEntry[]
  resourceTimesheetMonths          ResourceTimesheetMonth[]
  orgUnitMemberships               OrgUnitMembership[]
  orgGroupMemberships              OrgGroupMembership[]
  /// RFC-ORG-002 — au plus un ClientUser lié à cette fiche HUMAN.
  clientUserHumanLink              ClientUser?                       @relation("ClientUserHumanResource")
  /// RFC-ORG-004 — steward métier (HUMAN) sur ressources gouvernées.
  stewardedProjects                Project[]                         @relation("ProjectStewardResource")
  stewardedBudgets                 Budget[]                          @relation("BudgetStewardResource")
  stewardedBudgetLines             BudgetLine[]                      @relation("BudgetLineStewardResource")
  stewardedSuppliers               Supplier[]                        @relation("SupplierStewardResource")
  stewardedSupplierContracts       SupplierContract[]                @relation("SupplierContractStewardResource")
  stewardedStrategicObjectives     StrategicObjective[]              @relation("StrategicObjectiveStewardResource")

  @@unique([clientId, email])
  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, type])
}

// --- Organization client (RFC-ORG-001) ---

enum OrgUnitType {
  COMPANY
  DIRECTION
  DEPARTMENT
  SERVICE
  SITE
  TEAM
  COMMITTEE
  OTHER
}

enum OrgUnitStatus {
  ACTIVE
  ARCHIVED
}

enum OrgUnitMemberType {
  MANAGER
  MEMBER
  OBSERVER
}

enum OrgGroupType {
  BUSINESS
  COMMITTEE
  FUNCTIONAL
  SECURITY
  TRANSVERSE
  OTHER
}

enum OrgGroupStatus {
  ACTIVE
  ARCHIVED
}

enum OrgGroupMemberType {
  OWNER
  MEMBER
  OBSERVER
}

model OrgUnit {
  id          String        @id @default(cuid())
  clientId    String
  parentId    String?
  code        String?
  name        String
  description String?
  type        OrgUnitType
  status      OrgUnitStatus @default(ACTIVE)
  sortOrder   Int           @default(0)
  metadata    Json?
  createdAt   DateTime      @default(now())
  updatedAt   DateTime      @updatedAt
  archivedAt  DateTime?

  client   Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent   OrgUnit?            @relation("OrgUnitHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children OrgUnit[]           @relation("OrgUnitHierarchy")
  members  OrgUnitMembership[]

  /// RFC-ORG-003 — propriété organisationnelle (Direction / unité propriétaire)
  ownedProjects            Project[]            @relation("OrgUnitOwnedProject")
  ownedBudgets             Budget[]             @relation("OrgUnitOwnedBudget")
  ownedBudgetLines         BudgetLine[]         @relation("OrgUnitOwnedBudgetLine")
  ownedSuppliers           Supplier[]           @relation("OrgUnitOwnedSupplier")
  ownedSupplierContracts   SupplierContract[]   @relation("OrgUnitOwnedSupplierContract")
  ownedStrategicObjectives StrategicObjective[] @relation("OrgUnitOwnedStrategicObjective")

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, parentId])
  @@index([clientId, status])
}

model OrgUnitMembership {
  id         String            @id @default(cuid())
  clientId   String
  orgUnitId  String
  resourceId String
  roleTitle  String?
  memberType OrgUnitMemberType @default(MEMBER)
  startsAt   DateTime?
  endsAt     DateTime?
  createdAt  DateTime          @default(now())
  updatedAt  DateTime          @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  orgUnit  OrgUnit  @relation(fields: [orgUnitId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([orgUnitId, resourceId])
  @@index([clientId])
  @@index([clientId, orgUnitId])
  @@index([clientId, resourceId])
}

model OrgGroup {
  id          String         @id @default(cuid())
  clientId    String
  code        String?
  name        String
  description String?
  type        OrgGroupType
  status      OrgGroupStatus @default(ACTIVE)
  metadata    Json?
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt
  archivedAt  DateTime?

  client  Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members OrgGroupMembership[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, status])
}

model OrgGroupMembership {
  id         String             @id @default(cuid())
  clientId   String
  groupId    String
  resourceId String
  memberType OrgGroupMemberType @default(MEMBER)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  group    OrgGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([groupId, resourceId])
  @@index([clientId])
  @@index([clientId, groupId])
  @@index([clientId, resourceId])
}

// --- Projects MVP (RFC-PROJ-001) ---

/**
 * Projet structuré vs activité de suivi plus légère (même entité `Project` côté SI).
 */
enum ProjectKind {
  PROJECT
  ACTIVITY
}

enum ProjectType {
  TRANSFORMATION
  INFRASTRUCTURE
  APPLICATION
  CYBERSECURITY
  COMPLIANCE
  ORGANIZATION
  PROCUREMENT
  GOVERNANCE
}

enum ProjectStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectScenarioStatus {
  DRAFT
  SELECTED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

/// RFC-PLA-001 — plan d’actions (cockpit tâches)
enum ActionPlanStatus {
  DRAFT
  ACTIVE
  ON_HOLD
  COMPLETED
  CANCELLED
}

enum ActionPlanPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectCriticality {
  LOW
  MEDIUM
  HIGH
}

enum ProjectTaskStatus {
  DRAFT
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// RFC-PROJ-011 — dépendance simple entre tâches (MVP)
enum ProjectTaskDependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
}

/// RFC-PROJ-011 — activité dérivée d’une tâche
enum ProjectActivityFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum ProjectActivityStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

/// RFC-PROJ-RISK-001 — registre des risques projet
enum ProjectRiskStatus {
  OPEN
  MONITORED
  MITIGATED
  CLOSED
}

/// Criticité dérivée du score (probabilité × impact), persistée.
enum ProjectRiskCriticality {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum ProjectRiskTreatmentStrategy {
  AVOID
  REDUCE
  TRANSFER
  ACCEPT
}

/// RFC-PROJ-018 — catégorie d’impact métier (optionnel).
enum ProjectRiskImpactCategory {
  FINANCIAL
  OPERATIONAL
  LEGAL
  REPUTATION
}

enum ComplianceAssessmentStatus {
  COMPLIANT
  PARTIALLY_COMPLIANT
  NON_COMPLIANT
  NOT_APPLICABLE
}

enum ProjectMilestoneStatus {
  PLANNED
  ACHIEVED
  DELAYED
  CANCELLED
}

/**
 * RFC-PROJ-010 — liaison projet ↔ ligne budgétaire
 */
enum ProjectBudgetAllocationType {
  FULL
  PERCENTAGE
  FIXED
}

/**
 * RFC-PROJ-012 — fiche projet décisionnelle
 */
enum ProjectRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProjectArbitrationStatus {
  DRAFT
  TO_REVIEW
  VALIDATED
  REJECTED
}

/**
 * Statut par niveau d’arbitrage (Métier → Comité → Sponsor/CODIR).
 */
enum ProjectArbitrationLevelStatus {
  BROUILLON
  EN_COURS
  /// Dossier transmis ; en attente de décision (visa) avant validation ou refus.
  SOUMIS_VALIDATION
  VALIDE
  REFUSE
}

/**
 * Recommandation saisie par le COPIL / COPRO (pas dérivée automatiquement des indicateurs).
 */
enum ProjectCopilRecommendation {
  NOT_SET
  POURSUIVRE
  NE_PAS_ENGAGER
  SOUS_RESERVE
  REPORTER
  AJUSTER_CADRAGE
}

/**
 * Instantané fiche projet lors d’une validation d’arbitrage (niveau passé à VALIDE).
 */
enum ProjectSheetDecisionLevel {
  METIER
  COMITE
  CODIR
}

/**
 * Rôle catalogue équipe projet — aligné sur Project.sponsorUserId / ownerUserId lorsque renseigné.
 */
enum ProjectTeamRoleSystemKind {
  SPONSOR
  OWNER
}

/// Interne (client / équipe) vs externe (prestataire, partenaire) pour les noms libres.
enum ProjectTeamMemberAffiliation {
  INTERNAL
  EXTERNAL
}

/// RFC-PROJ-013 — point projet (COPIL / COPRO / …)
enum ProjectReviewType {
  COPIL
  COPRO
  CODIR_REVIEW
  RISK_REVIEW
  MILESTONE_REVIEW
  AD_HOC
  /// Retour d'expérience — bilan de fin de projet (terminés / annulés / archivés uniquement)
  POST_MORTEM
}

enum ProjectReviewStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

/// RFC-PROJ-DOC-001 — registre métier documentaire projet (sans stockage binaire MVP)
enum ProjectDocumentStorageType {
  STARIUM
  EXTERNAL
  MICROSOFT
}

enum ProjectDocumentStatus {
  ACTIVE
  ARCHIVED
  DELETED
}

enum ProjectDocumentCategory {
  GENERAL
  CONTRACT
  SPECIFICATION
  DELIVERABLE
  REPORT
  FINANCIAL
  COMPLIANCE
  OTHER
}

enum StrategicObjectiveStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
  COMPLETED
  ARCHIVED
}

/// RFC-STRAT-007 — cycle de vie objectif (séparé de la santé).
enum StrategicObjectiveLifecycleStatus {
  DRAFT
  ACTIVE
  COMPLETED
  ARCHIVED
}

/// RFC-STRAT-007 — santé objectif (séparé du cycle de vie).
enum StrategicObjectiveHealthStatus {
  ON_TRACK
  AT_RISK
  OFF_TRACK
}

/// RFC-STRAT-007 — statut métier de la vision (compat additive avec isActive).
enum StrategicVisionStatus {
  DRAFT
  ACTIVE
  ARCHIVED
}

/// RFC-STRAT-007 — statut métier de l'axe.
enum StrategicAxisStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

/// RFC-STRAT-007 — types de liens stratégiques. PROJECT et MANUAL sont supportés en write V1 ;
/// BUDGET / BUDGET_LINE / RISK / GOVERNANCE_CYCLE sont présents pour compat future mais refusés en write MVP.
enum StrategicLinkType {
  PROJECT
  BUDGET
  RISK
  BUDGET_LINE
  GOVERNANCE_CYCLE
  MANUAL
}

enum StrategicDirectionStrategyStatus {
  DRAFT
  SUBMITTED
  APPROVED
  REJECTED
  ARCHIVED
}

model Project {
  id          String  @id @default(cuid())
  clientId    String
  name        String
  code        String
  description String?
  /// Texte de recherche normalisé (concat champs clés) — RFC-CORE-SEARCH-001
  searchText  String? @db.Text

  kind     ProjectKind     @default(PROJECT)
  type     ProjectType
  status   ProjectStatus
  priority ProjectPriority

  sponsorUserId       String?
  ownerUserId         String?
  portfolioCategoryId String?
  /// RFC-ORG-003 — unité organisationnelle propriétaire (nullable en V1)
  ownerOrgUnitId      String?
  /// RFC-ORG-004 — responsable métier (Resource HUMAN), distinct de la Direction propriétaire.
  stewardResourceId   String?
  /// Responsable hors compte (dénormalisé ; aligné avec entrée équipe « Responsable » nom libre).
  ownerFreeLabel      String?                       @db.VarChar(200)
  ownerAffiliation    ProjectTeamMemberAffiliation?

  startDate     DateTime?
  targetEndDate DateTime?
  actualEndDate DateTime?

  criticality     ProjectCriticality
  progressPercent Int?

  targetBudgetAmount Decimal? @db.Decimal(18, 2)
  pilotNotes         String?

  businessValueScore Int?
  strategicAlignment Int?
  urgencyScore       Int?

  estimatedCost                Decimal?                       @db.Decimal(18, 2)
  estimatedGain                Decimal?                       @db.Decimal(18, 2)
  roi                          Decimal?                       @db.Decimal(10, 2)
  riskLevel                    ProjectRiskLevel?
  /// Réponse au risque : traitement, mitigation, plan d’action (texte libre, fiche CODIR)
  riskResponse                 String?
  priorityScore                Decimal?                       @db.Decimal(5, 2)
  /// Dérivé des trois niveaux (rétrocompat lecture / exports).
  arbitrationStatus            ProjectArbitrationStatus?
  arbitrationMetierStatus      ProjectArbitrationLevelStatus  @default(BROUILLON)
  arbitrationComiteStatus      ProjectArbitrationLevelStatus?
  arbitrationCodirStatus       ProjectArbitrationLevelStatus?
  arbitrationMetierRefusalNote String?                        @db.VarChar(2000)
  arbitrationComiteRefusalNote String?                        @db.VarChar(2000)
  arbitrationCodirRefusalNote  String?                        @db.VarChar(2000)
  copilRecommendation          ProjectCopilRecommendation     @default(NOT_SET)
  /// Commentaire libre associé à la position COPIL (visible sur demande à l’UI).
  copilRecommendationNote      String?                        @db.VarChar(4000)

  /// Cadrage OQQCQPC (fiche projet)
  cadreLocation String? @db.VarChar(500)
  cadreQui      String? @db.VarChar(500)

  /// Équipes / directions impliquées (texte libre, fiche projet)
  involvedTeams String? @db.VarChar(2000)

  /// RFC-PROJ-012 — objectif métier (texte MVP)
  businessProblem     String?
  businessBenefits    String?
  /// KPI de succès — liste de lignes (JSON string[])
  businessSuccessKpis Json?

  /// SWOT / TOWS — JSON (tableaux de strings ; contraintes en DTO)
  swotStrengths     Json?
  swotWeaknesses    Json?
  swotOpportunities Json?
  swotThreats       Json?
  towsActions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client                 Client                         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sponsor                User?                          @relation("ProjectSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  owner                  User?                          @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerOrgUnit           OrgUnit?                       @relation("OrgUnitOwnedProject", fields: [ownerOrgUnitId], references: [id], onDelete: Restrict)
  steward                Resource?                      @relation("ProjectStewardResource", fields: [stewardResourceId], references: [id], onDelete: SetNull)
  portfolioCategory      ProjectPortfolioCategory?      @relation(fields: [portfolioCategoryId], references: [id], onDelete: SetNull)
  microsoftLink          ProjectMicrosoftLink?
  microsoftTaskSyncs     ProjectTaskMicrosoftSync[]
  microsoftDocumentSyncs ProjectDocumentMicrosoftSync[]

  tasks                     ProjectTask[]
  taskPhases                ProjectTaskPhase[]
  taskBuckets               ProjectTaskBucket[]
  taskChecklistItems        ProjectTaskChecklistItem[]
  taskLabels                ProjectTaskLabel[]
  taskLabelAssignments      ProjectTaskLabelAssignment[]
  risks                     ProjectRisk[]
  milestones                ProjectMilestone[]
  milestoneLabels           ProjectMilestoneLabel[]
  milestoneLabelAssignments ProjectMilestoneLabelAssignment[]
  activities                ProjectActivity[]
  budgetLinks               ProjectBudgetLink[]
  scenarios                 ProjectScenario[]
  scenarioCapacitySnapshots ProjectScenarioCapacitySnapshot[]
  teamMembers               ProjectTeamMember[]
  tagAssignments            ProjectTagAssignment[]
  sheetDecisionSnapshots    ProjectSheetDecisionSnapshot[]
  projectReviews            ProjectReview[]
  projectReviewActionItems  ProjectReviewActionItem[]
  documents                 ProjectDocument[]
  resourceTimeEntries       ResourceTimeEntry[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, status])
  @@index([clientId, kind])
  @@index([clientId, portfolioCategoryId])
  @@index([clientId, ownerOrgUnitId])
  @@index([clientId, stewardResourceId])
  @@index([targetEndDate])
}

model StrategicVision {
  id           String                @id @default(cuid())
  clientId     String
  title        String
  statement    String
  horizonLabel String
  isActive     Boolean               @default(false)
  status       StrategicVisionStatus @default(DRAFT)
  createdAt    DateTime              @default(now())
  updatedAt    DateTime              @updatedAt

  client              Client                       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  axes                StrategicAxis[]
  directionStrategies StrategicDirectionStrategy[]

  @@index([clientId])
  @@index([clientId, isActive])
  @@index([clientId, status])
}

model StrategicAxis {
  id          String              @id @default(cuid())
  clientId    String
  visionId    String
  name        String
  description String?
  code        String?
  sortOrder   Int?
  orderIndex  Int?
  status      StrategicAxisStatus @default(ACTIVE)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  client                     Client                               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  vision                     StrategicVision                      @relation(fields: [visionId], references: [id], onDelete: Cascade)
  objectives                 StrategicObjective[]
  directionStrategyAxisLinks StrategicDirectionStrategyAxisLink[]

  @@index([clientId])
  @@index([clientId, visionId])
  @@index([clientId, status])
}

model StrategicObjective {
  id              String                            @id @default(cuid())
  clientId        String
  axisId          String
  directionId     String?
  /// RFC-ORG-003 — unité organisationnelle propriétaire (distinct de directionId / StrategicDirection)
  ownerOrgUnitId    String?
  /// RFC-ORG-004
  stewardResourceId String?
  title           String
  description     String?
  ownerLabel      String?
  ownerUserId     String?
  status          StrategicObjectiveStatus          @default(ON_TRACK)
  lifecycleStatus StrategicObjectiveLifecycleStatus @default(ACTIVE)
  healthStatus    StrategicObjectiveHealthStatus?
  progressPercent Int?
  deadline        DateTime?
  targetDate      DateTime?
  createdAt       DateTime                          @default(now())
  updatedAt       DateTime                          @updatedAt

  client                          Client                                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  axis                            StrategicAxis                             @relation(fields: [axisId], references: [id], onDelete: Cascade)
  direction                       StrategicDirection?                       @relation(fields: [directionId], references: [id], onDelete: SetNull)
  ownerOrgUnit                    OrgUnit?                                  @relation("OrgUnitOwnedStrategicObjective", fields: [ownerOrgUnitId], references: [id], onDelete: Restrict)
  steward                         Resource?                                 @relation("StrategicObjectiveStewardResource", fields: [stewardResourceId], references: [id], onDelete: SetNull)
  ownerUser                       User?                                     @relation("StrategicObjectiveOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  links                           StrategicLink[]
  directionStrategyObjectiveLinks StrategicDirectionStrategyObjectiveLink[]

  @@index([clientId])
  @@index([clientId, axisId])
  @@index([clientId, directionId])
  @@index([clientId, status])
  @@index([clientId, lifecycleStatus])
  @@index([clientId, deadline])
  @@index([clientId, targetDate])
  @@index([clientId, ownerUserId])
  @@index([clientId, ownerOrgUnitId])
  @@index([clientId, stewardResourceId])
}

model StrategicDirection {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client     Client                      @relation(fields: [clientId], references: [id], onDelete: Cascade)
  objectives StrategicObjective[]
  strategies StrategicDirectionStrategy[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, isActive])
}

model StrategicDirectionStrategy {
  id               String                           @id @default(cuid())
  clientId         String
  directionId      String
  alignedVisionId  String
  title            String?
  ambition         String?
  context          String?
  statement        String
  strategicPriorities Json?
  expectedOutcomes Json?
  kpis             Json?
  majorInitiatives Json?
  risks            Json?
  horizonLabel     String
  ownerLabel       String?
  status           StrategicDirectionStrategyStatus @default(DRAFT)
  submittedAt      DateTime?
  submittedByUserId String?
  approvedAt       DateTime?
  approvedByUserId String?
  rejectionReason  String?
  archivedReason   String?
  archivedAt       DateTime?
  createdAt        DateTime                         @default(now())
  updatedAt        DateTime                         @updatedAt

  client        Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  direction     StrategicDirection @relation(fields: [directionId], references: [id], onDelete: Cascade)
  alignedVision StrategicVision    @relation(fields: [alignedVisionId], references: [id], onDelete: Cascade)
  approvedBy    User?              @relation("StrategicDirectionStrategyApprovedBy", fields: [approvedByUserId], references: [id], onDelete: SetNull)
  axisLinks      StrategicDirectionStrategyAxisLink[]
  objectiveLinks StrategicDirectionStrategyObjectiveLink[]

  /// Une seule stratégie **non archivée** par (client, direction, vision) — garanti par index partiel SQL (migration).
  @@index([clientId])
  @@index([clientId, directionId])
  @@index([clientId, status])
}

