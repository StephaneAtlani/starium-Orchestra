  project Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  task    ProjectTask @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)

  @@unique([projectTaskId, plannerChecklistItemKey])
  @@index([clientId])
  @@index([projectId])
  @@index([projectTaskId])
}

/// Définition d’étiquette « Starium » pour une tâche projet (peut être liée à une catégorie Planner Microsoft).
model ProjectTaskLabel {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  name      String
  color     String?
  sortOrder Int     @default(0)

  /// Clé catégorie Planner Microsoft (`category1`..`category25` via v1.0/Graph plan details).
  plannerCategoryId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignments ProjectTaskLabelAssignment[]

  @@unique([clientId, projectId, name])
  @@index([clientId])
  @@index([projectId])
}

model ProjectTaskLabelAssignment {
  id String @id @default(cuid())

  clientId  String
  projectId String

  projectTaskId String
  labelId       String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  task  ProjectTask      @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)
  label ProjectTaskLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([clientId, projectTaskId, labelId])
  @@index([clientId])
  @@index([projectId])
  @@index([projectTaskId])
  @@index([labelId])
}

/// Définition d’étiquette « Starium » pour un jalon projet.
model ProjectMilestoneLabel {
  id String @id @default(cuid())

  clientId  String
  projectId String

  name      String
  color     String?
  sortOrder Int     @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  assignments ProjectMilestoneLabelAssignment[]

  @@unique([clientId, projectId, name])
  @@index([clientId])
  @@index([projectId])
}

model ProjectMilestoneLabelAssignment {
  id String @id @default(cuid())

  clientId  String
  projectId String

  projectMilestoneId String
  labelId            String

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  milestone ProjectMilestone      @relation(fields: [projectMilestoneId], references: [id], onDelete: Cascade)
  label     ProjectMilestoneLabel @relation(fields: [labelId], references: [id], onDelete: Cascade)

  @@unique([clientId, projectMilestoneId, labelId])
  @@index([clientId])
  @@index([projectId])
  @@index([projectMilestoneId])
  @@index([labelId])
}

/// Instance référentiel conformité par client (MVP — pas de catalogue global).
model ComplianceFramework {
  id        String   @id @default(cuid())
  clientId  String
  name      String
  version   String
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client       Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requirements ComplianceRequirement[]

  @@unique([clientId, name, version])
  @@index([clientId])
}

model ComplianceRequirement {
  id          String   @id @default(cuid())
  frameworkId String
  code        String
  title       String
  description String?
  category    String?
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  framework    ComplianceFramework  @relation(fields: [frameworkId], references: [id], onDelete: Cascade)
  statuses     ComplianceStatus[]
  evidences    ComplianceEvidence[]
  projectRisks ProjectRisk[]

  @@unique([frameworkId, code])
  @@index([frameworkId])
}

model ComplianceStatus {
  id                 String                     @id @default(cuid())
  clientId           String
  requirementId      String
  status             ComplianceAssessmentStatus
  lastAssessmentDate DateTime?
  comment            String?
  createdAt          DateTime                   @default(now())
  updatedAt          DateTime                   @updatedAt

  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requirement ComplianceRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@unique([clientId, requirementId])
  @@index([clientId])
  @@index([requirementId])
}

model ComplianceEvidence {
  id              String   @id @default(cuid())
  clientId        String
  requirementId   String
  name            String
  description     String?
  url             String?
  fileId          String?
  createdByUserId String?
  createdAt       DateTime @default(now())

  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  requirement ComplianceRequirement @relation(fields: [requirementId], references: [id], onDelete: Cascade)

  @@index([clientId, requirementId])
}

/// Domaine de risque configurable (taxonomie client, 1 → N types).
model RiskDomain {
  id          String     @id @default(cuid())
  clientId    String
  client      Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  code        String
  name        String
  description String?
  isActive    Boolean    @default(true)
  isVisibleInCatalog Boolean @default(true)
  types       RiskType[]
  createdAt   DateTime   @default(now())
  updatedAt   DateTime   @updatedAt

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, isVisibleInCatalog])
}

/// Type de risque sous un domaine (taxonomie client).
model RiskType {
  id            String                @id @default(cuid())
  clientId      String
  domainId      String
  client        Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  domain        RiskDomain            @relation(fields: [domainId], references: [id], onDelete: Restrict)
  code          String
  name          String
  isActive      Boolean               @default(true)
  isVisibleInCatalog Boolean          @default(true)
  isRecommended Boolean               @default(false)
  projectRisks  ProjectRisk[]
  scenarioRisks ProjectScenarioRisk[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt

  @@unique([domainId, code])
  @@index([clientId])
  @@index([domainId])
  @@index([clientId, isVisibleInCatalog, isRecommended])
}

/// RFC-PROJ-RISK-001 — risque projet (registre) ; peut être hors projet (`projectId` null).
model ProjectRisk {
  id        String  @id @default(cuid())
  clientId  String
  projectId String?

  code        String
  title       String
  /// Scénario structuré type « Si X alors Y » (peut être renommé riskScenario en migration ultérieure).
  description String?
  category    String?

  /// RFC-PROJ-018 — origine de la menace (ex. cyberattaque, fournisseur).
  threatSource            String                     @default("—")
  /// RFC-PROJ-018 — conséquences pour l’organisation.
  businessImpact          String                     @default("—")
  /// Justification du score de probabilité (optionnel).
  likelihoodJustification String?
  impactCategory          ProjectRiskImpactCategory?

  /// 1–5
  probability      Int
  /// 1–5
  impact           Int
  criticalityScore Int
  criticalityLevel ProjectRiskCriticality

  mitigationPlan  String?
  contingencyPlan String?
  ownerUserId     String?

  status     ProjectRiskStatus
  reviewDate DateTime?
  dueDate    DateTime?
  detectedAt DateTime?
  closedAt   DateTime?
  sortOrder  Int               @default(0)

  complianceRequirementId String?
  treatmentStrategy       ProjectRiskTreatmentStrategy
  residualRiskLevel       ProjectRiskCriticality?
  /// RFC-PROJ-018 — justification du niveau résiduel (optionnel).
  residualJustification   String?
  /// Traitement / mesures complémentaires après évaluation du résiduel (optionnel).
  complementaryTreatmentMeasures String?

  /// Classification métier : FK vers `RiskType` (domaine dérivé via jointure).
  riskTypeId String
  riskType   RiskType @relation(fields: [riskTypeId], references: [id], onDelete: Restrict)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client                Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project               Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  owner                 User?                  @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)
  complianceRequirement ComplianceRequirement? @relation(fields: [complianceRequirementId], references: [id], onDelete: SetNull)

  tasks ProjectTask[]

  /// Unicité (projectId, code) et (clientId, code) pour projectId null : index partiels SQL — voir migration.
  @@index([clientId])
  @@index([projectId])
  @@index([projectId, sortOrder])
  @@index([complianceRequirementId])
  @@index([riskTypeId])
}

/// RFC-PROJ-011 — jalon (sans durée)
model ProjectMilestone {
  id           String  @id @default(cuid())
  clientId     String
  projectId    String
  linkedTaskId String?
  phaseId      String?

  code        String?
  name        String
  description String?

  status       ProjectMilestoneStatus @default(PLANNED)
  targetDate   DateTime
  achievedDate DateTime?

  sortOrder Int @default(0)

  ownerUserId String?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client            @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project    Project           @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedTask ProjectTask?      @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)
  phase      ProjectTaskPhase? @relation(fields: [phaseId], references: [id], onDelete: SetNull)

  ownerUser     User? @relation("ProjectMilestoneOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("ProjectMilestoneCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProjectMilestoneUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  labelAssignments ProjectMilestoneLabelAssignment[]

  @@index([clientId])
  @@index([projectId])
  @@index([linkedTaskId])
  @@index([phaseId])
  @@index([projectId, phaseId])
  @@index([targetDate])
  @@index([status])
}

/// RFC-PROJ-011 — activité dérivée d’une tâche (hors Gantt MVP)
model ProjectActivity {
  id           String @id @default(cuid())
  clientId     String
  projectId    String
  sourceTaskId String

  name        String
  description String?

  status      ProjectActivityStatus    @default(ACTIVE)
  frequency   ProjectActivityFrequency
  customRrule String?

  nextExecutionDate DateTime?
  lastExecutionDate DateTime?

  ownerUserId  String?
  budgetLineId String?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTask ProjectTask @relation(fields: [sourceTaskId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  ownerUser     User? @relation("ProjectActivityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("ProjectActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProjectActivityUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([sourceTaskId])
  @@index([status])
  @@index([nextExecutionDate])
}

