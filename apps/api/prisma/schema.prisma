  @@index([clientId])
  @@index([supplierId])
  @@index([budgetLineId])
  @@index([clientId, supplierId])
}

/// RFC-034 Phase 1 — GED pièces jointes ; exactement un parent PO **ou** facture (contrainte CHECK migration).
model ProcurementAttachment {
  id              String  @id @default(cuid())
  clientId        String
  purchaseOrderId String?
  invoiceId       String?

  name             String
  originalFilename String?
  mimeType         String?
  extension        String?
  sizeBytes        Int?

  category    ProcurementAttachmentCategory @default(OTHER)
  status      ProcurementAttachmentStatus   @default(ACTIVE)
  storageType ProcurementStorageType        @default(STARIUM)

  storageBucket  String
  objectKey      String
  checksumSha256 String?

  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?

  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  purchaseOrder  PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: Cascade)
  invoice        Invoice?       @relation(fields: [invoiceId], references: [id], onDelete: Cascade)
  uploadedByUser User?          @relation("ProcurementAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([purchaseOrderId])
  @@index([invoiceId])
  @@index([clientId, purchaseOrderId])
  @@index([clientId, invoiceId])
}

/// RFC-036 — registre contractuel client + fournisseur.
/// Types de contrat : `clientId` null = catalogue plateforme (RFC-036).
model SupplierContractKindType {
  id          String   @id @default(cuid())
  clientId    String?
  code        String   @db.VarChar(64)
  label       String   @db.VarChar(200)
  description String?  @db.VarChar(1000)
  sortOrder   Int      @default(0)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client? @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId, isActive, sortOrder])
}

model SupplierContract {
  id         String @id @default(cuid())
  clientId   String
  supplierId String
  /// RFC-ORG-003
  ownerOrgUnitId String?
  /// RFC-ORG-004
  stewardResourceId String?

  reference String
  title     String

  /// Code métier aligné sur `SupplierContractKindType.code` (catalogue plateforme ou types client).
  kind   String                 @db.VarChar(64)
  status SupplierContractStatus @default(DRAFT)

  signedAt       DateTime?
  effectiveStart DateTime
  effectiveEnd   DateTime?
  terminatedAt   DateTime?

  renewalMode       SupplierContractRenewalMode @default(NONE)
  noticePeriodDays  Int?
  renewalTermMonths Int?

  currency            String   @db.VarChar(3)
  annualValue         Decimal? @db.Decimal(18, 2)
  totalCommittedValue Decimal? @db.Decimal(18, 2)
  billingFrequency    String?  @db.VarChar(32)

  description   String? @db.VarChar(4000)
  internalNotes String? @db.VarChar(4000)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client      Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier    Supplier             @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  ownerOrgUnit OrgUnit?            @relation("OrgUnitOwnedSupplierContract", fields: [ownerOrgUnitId], references: [id], onDelete: Restrict)
  steward      Resource?           @relation("SupplierContractStewardResource", fields: [stewardResourceId], references: [id], onDelete: SetNull)
  attachments ContractAttachment[]

  @@unique([clientId, reference])
  @@index([clientId])
  @@index([clientId, supplierId])
  @@index([clientId, status])
  @@index([clientId, effectiveEnd])
  @@index([clientId, ownerOrgUnitId])
  @@index([clientId, stewardResourceId])
}

/// RFC-036 — pièce jointe contrat (stockage aligné procurement).
model ContractAttachment {
  id                 String @id @default(cuid())
  clientId           String
  supplierContractId String

  name             String
  originalFilename String?
  mimeType         String?
  extension        String?
  sizeBytes        Int?

  category    ContractAttachmentCategory  @default(OTHER)
  status      ProcurementAttachmentStatus @default(ACTIVE)
  storageType ProcurementStorageType      @default(STARIUM)

  storageBucket  String
  objectKey      String
  checksumSha256 String?

  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?

  client           Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplierContract SupplierContract @relation(fields: [supplierContractId], references: [id], onDelete: Cascade)
  uploadedByUser   User?            @relation("ContractAttachmentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([supplierContractId])
  @@index([clientId, supplierContractId])
}

// --- Budget Import (RFC-018) ---

enum BudgetImportSourceType {
  CSV
  XLSX
}

enum BudgetImportEntityType {
  BUDGET_LINES
}

enum BudgetImportTargetEntityType {
  BUDGET_LINE
}

enum BudgetImportJobStatus {
  ANALYZED
  PREVIEWED
  RUNNING
  COMPLETED
  FAILED
}

enum BudgetImportMode {
  CREATE_ONLY
  UPSERT
  UPDATE_ONLY
}

model BudgetImportMapping {
  id             String                 @id @default(cuid())
  clientId       String
  name           String
  description    String?
  sourceType     BudgetImportSourceType
  entityType     BudgetImportEntityType @default(BUDGET_LINES)
  sheetName      String?
  headerRowIndex Int                    @default(1)
  mappingConfig  Json
  optionsConfig  Json?
  createdById    String?
  createdAt      DateTime               @default(now())
  updatedAt      DateTime               @updatedAt

  client    Client            @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?             @relation(fields: [createdById], references: [id], onDelete: SetNull)
  jobs      BudgetImportJob[]

  @@index([clientId])
}

model BudgetImportJob {
  id          String                 @id @default(cuid())
  clientId    String
  budgetId    String
  mappingId   String?
  fileName    String
  sourceType  BudgetImportSourceType
  status      BudgetImportJobStatus
  importMode  BudgetImportMode
  totalRows   Int                    @default(0)
  createdRows Int                    @default(0)
  updatedRows Int                    @default(0)
  skippedRows Int                    @default(0)
  errorRows   Int                    @default(0)
  summary     Json?
  createdById String?
  createdAt   DateTime               @default(now())

  client    Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget    Budget                @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  mapping   BudgetImportMapping?  @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  createdBy User?                 @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rowLinks  BudgetImportRowLink[]

  @@index([clientId, budgetId])
  @@index([mappingId])
}

model BudgetImportRowLink {
  id               String                       @id @default(cuid())
  clientId         String
  budgetId         String
  importJobId      String
  targetEntityType BudgetImportTargetEntityType @default(BUDGET_LINE)
  targetEntityId   String
  sourceRowNumber  Int?
  externalId       String?
  compositeHash    String?
  fingerprintData  Json?
  createdAt        DateTime                     @default(now())

  client    Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importJob BudgetImportJob @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([clientId, budgetId, targetEntityType, targetEntityId])
  @@index([clientId, budgetId, externalId])
  @@index([clientId, budgetId, compositeHash])
}

// --- End Budget MVP ---

model RefreshToken {
  id        String    @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime  @default(now())
  revokedAt DateTime?
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

/// Paramètres 2FA TOTP par utilisateur (un seul enregistrement par user).
model UserMfa {
  id                  String    @id @default(cuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Secret TOTP chiffré (AES-256-GCM) — présent dès l’init d’enrollment ou après activation
  totpSecretEncrypted String?
  totpPending         Boolean   @default(false)
  totpEnabledAt       DateTime?
  /// Codes de secours : tableau JSON de hash bcrypt (jamais en clair)
  backupCodesHashes   Json?
  /// Version de la clé de chiffrement utilisée pour totpSecretEncrypted
  keyVersion          Int       @default(1)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model MfaChallenge {
  id           String              @id @default(cuid())
  userId       String
  user         User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose      MfaChallengePurpose
  channel      MfaChallengeChannel @default(TOTP)
  /// OTP email (fallback) : hash du code à usage unique
  otpCodeHash  String?
  emailSentAt  DateTime?
  expiresAt    DateTime
  attemptCount Int                 @default(0)
  consumedAt   DateTime?
  createdAt    DateTime            @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Jeton opaque (hash stocké) : « appareil de confiance » pour éviter la 2FA à chaque login (durée limitée).
model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id String @id @default(cuid())

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

/// Journal d’audit **plateforme** (sans `clientId` métier) — ex. archives chatbot `scope=GLOBAL` (RFC-AI-001).
model PlatformAuditLog {
  id String @id @default(cuid())

  userId String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id], onDelete: SetNull)
  stariumFeedbackReplies PlatformStariumFeedbackReply[]

  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType])
}

/// Réponse d’un administrateur plateforme à un retour widget Cursor Starium (journal `PlatformAuditLog`).
model PlatformStariumFeedbackReply {
  id                 String   @id @default(cuid())
  platformAuditLogId String
  authorUserId       String
  body               String
  createdAt          DateTime @default(now())

  auditLog PlatformAuditLog @relation(fields: [platformAuditLogId], references: [id], onDelete: Cascade)
  author   User             @relation("PlatformStariumFeedbackReplyAuthor", fields: [authorUserId], references: [id], onDelete: Cascade)

  @@index([platformAuditLogId])
  @@index([authorUserId])
  @@index([createdAt])
}

/// Périmètre d’une entrée ou catégorie chatbot (plateforme vs client).
enum ChatbotKnowledgeScope {
  GLOBAL
  CLIENT
}

enum ChatbotKnowledgeEntryType {
  FAQ
  ARTICLE
}

enum ChatbotMessageRole {
  USER
  ASSISTANT
}

model ChatbotCategory {
  id          String                @id @default(cuid())
  name        String
  slug        String
  description String?
  icon        String?
  isFeatured  Boolean               @default(false)
  scope       ChatbotKnowledgeScope
  clientId    String?
  isActive    Boolean               @default(true)
  archivedAt  DateTime?
  order       Int                   @default(0)
  createdAt   DateTime              @default(now())
  updatedAt   DateTime              @updatedAt

  client  Client?                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  entries ChatbotKnowledgeEntry[]

  @@index([scope, isActive, order])
  @@index([clientId, isActive, order])
  @@index([scope, slug])
  @@index([scope, clientId, slug])
}

model ChatbotKnowledgeEntry {
  id                 String                   @id @default(cuid())
  slug               String
  title              String
  question           String
  answer             String
  keywords           String[]                 @default([])
  tags               String[]                 @default([])
  moduleCode         String?
  targetRole         ClientUserRole?
  requiredPermission String?
  categoryId         String?
  type               ChatbotKnowledgeEntryType
  scope              ChatbotKnowledgeScope
  clientId           String?
  isActive           Boolean                  @default(true)
  archivedAt         DateTime?
  priority           Int                      @default(0)
  isFeatured         Boolean                  @default(false)
  isPopular          Boolean                  @default(false)
  icon               String?
  content            String?
  /// Texte de recherche normalisé (title, question, answer, content, keywords, tags, slug) — RFC-CORE-SEARCH-001
  searchText         String? @db.Text
  indexedAt          DateTime?
  structuredLinks    Json?
  relatedEntryIds    String[]                 @default([])
  createdByUserId    String
  updatedByUserId    String
  createdAt          DateTime                 @default(now())
  updatedAt          DateTime                 @updatedAt

  category    ChatbotCategory? @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  client      Client?          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy   User             @relation("ChatbotEntryCreatedBy", fields: [createdByUserId], references: [id], onDelete: Restrict)
  updatedBy   User             @relation("ChatbotEntryUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: Restrict)

  @@index([scope, isActive, priority])
  @@index([clientId, isActive, priority])
  @@index([moduleCode, requiredPermission, isActive])
  @@index([scope, slug])
  @@index([scope, clientId, slug])
}

model ChatbotConversation {
  id        String   @id @default(cuid())
  clientId  String
  userId    String
  title     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  messages ChatbotMessage[]

  @@index([clientId, userId, updatedAt])
}

model ChatbotMessage {
  id                   String             @id @default(cuid())
  conversationId     String
  clientId             String
  userId               String
  role                 ChatbotMessageRole
  content              String
  matchedEntryId       String?
  noAnswerFallbackUsed Boolean            @default(false)
  createdAt            DateTime           @default(now())

  conversation ChatbotConversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt])
  @@index([clientId, userId, createdAt])
}

model Alert {
  id           String        @id @default(cuid())
  clientId     String
  type         AlertType
  severity     AlertSeverity
  title        String
  message      String
  entityType   String?
  entityId     String?
  entityLabel  String?
  actionUrl    String?
  status       AlertStatus   @default(ACTIVE)
  ruleCode     String
  metadata     Json?
  resolvedAt   DateTime?
  dismissedAt  DateTime?
  resolvedById String?
  dismissedById String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt

  client      Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resolvedBy  User?          @relation("AlertResolvedBy", fields: [resolvedById], references: [id], onDelete: SetNull)
  dismissedBy User?          @relation("AlertDismissedBy", fields: [dismissedById], references: [id], onDelete: SetNull)
  notifications Notification[]
  emailDeliveries EmailDelivery[]

  @@index([clientId, status, severity])
  @@index([clientId, type, severity, entityType, entityId, ruleCode, status])
  @@index([clientId, createdAt])
}

model Notification {
  id           String             @id @default(cuid())
  clientId     String
  userId       String
  alertId      String?
  type         NotificationType   @default(ALERT)
  title        String
  message      String
  status       NotificationStatus @default(UNREAD)
  entityType   String?
  entityId     String?
  entityLabel  String?
  actionUrl    String?
  alertSeverity AlertSeverity?
  metadata     Json?
  readAt       DateTime?
  createdAt    DateTime           @default(now())

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  alert  Alert? @relation(fields: [alertId], references: [id], onDelete: SetNull)

  @@index([clientId, userId, status])
  @@index([clientId, userId, createdAt])
  @@index([alertId])
}

model EmailDelivery {
  id              String              @id @default(cuid())
  clientId        String
  alertId         String?
  recipient       String
  subject         String
  /// Lien CTA (ex. vérification e-mail) — requis au traitement async car non porté par Alert.
  actionUrl          String?
  /// Titre / message affichés dans le template au moment de l’envoi (évite une recomposition incorrecte depuis subject seul).
  emailBodyTitle     String?
  emailBodyMessage   String?
  templateKey     String
  status          EmailDeliveryStatus @default(PENDING)
  attempts        Int                 @default(0)
  lastError       String?
  providerMessageId String?
  sentAt          DateTime?
  createdByUserId String?
  createdAt       DateTime            @default(now())
  updatedAt       DateTime            @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  alert  Alert? @relation(fields: [alertId], references: [id], onDelete: SetNull)
  createdBy User? @relation("EmailDeliveryCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientId, status, createdAt])
  @@index([alertId])
  @@index([recipient])
}

model AuditLogArchive {
  id String @id

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType])
}

model SecurityLog {
  id String @id @default(cuid())

  event String

  userId String?
  email  String?

  success Boolean
  reason  String?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}

model MicrosoftOAuthState {
  id             String    @id @default(cuid())
  stateTokenHash String    @unique
  userId         String?
  clientId       String?
  /// Redirect URI OAuth utilisée pour cette demande (SSO plateforme ou connexion client).
  redirectUri    String?
  /// Résultat final (URL succès/erreur) mémorisé après le 1ᵉʳ callback : permet l’idempotence sur retry (proxy, prefetch).
  redirectResultUrl String?
  expiresAt      DateTime
  consumedAt     DateTime?
  createdAt      DateTime  @default(now())

  @@index([expiresAt])
  @@index([consumedAt])
}

/// Connexion OAuth Microsoft 365 par client Starium (tokens chiffrés côté API uniquement).
model MicrosoftConnection {
  id                    String                    @id @default(cuid())
  clientId              String
  tenantId              String
  tenantName            String?
  status                MicrosoftConnectionStatus @default(ACTIVE)
  authMode              MicrosoftAuthMode         @default(DELEGATED)
  accessTokenEncrypted  String?
  refreshTokenEncrypted String?
  tokenExpiresAt        DateTime?
  connectedByUserId     String?
  createdAt             DateTime                  @default(now())
  updatedAt             DateTime                  @updatedAt

  client          Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  connectedByUser User?                  @relation("MicrosoftConnectedBy", fields: [connectedByUserId], references: [id], onDelete: SetNull)
  projectLinks    ProjectMicrosoftLink[]

  @@unique([clientId, tenantId])
  @@index([clientId])
  @@index([status])
}

/// Pré-requis de rattrapage repo : persistance du lien projet ↔ Microsoft (RFC-PROJ-INT-007).
model ProjectMicrosoftLink {
  id String @id @default(cuid())

  clientId              String
  projectId             String  @unique
  microsoftConnectionId String?

  isEnabled Boolean @default(false)

  teamId           String?
  teamName         String?
  channelId        String?
  channelName      String?
  plannerPlanId    String?
  plannerPlanTitle String?

  filesDriveId  String?
  filesFolderId String?

  syncTasksEnabled           Boolean @default(true)
  syncDocumentsEnabled       Boolean @default(true)
  /// Si true : les buckets du planning sont ceux du plan Planner (remplace les buckets Starium).
  useMicrosoftPlannerBuckets Boolean @default(false)

  /// Si true : la sync Planner inclut aussi les labels Microsoft (Planner categories).
  useMicrosoftPlannerLabels Boolean @default(false)

  lastSyncAt DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client              Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project             Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  microsoftConnection MicrosoftConnection? @relation(fields: [microsoftConnectionId], references: [id], onDelete: SetNull)

  taskSyncs     ProjectTaskMicrosoftSync[]
  documentSyncs ProjectDocumentMicrosoftSync[]

  @@index([clientId])
  @@index([microsoftConnectionId])
}

/// RFC-PROJ-INT-009 — mapping sync one-way ProjectDocument → Teams/SharePoint drive.
model ProjectDocumentMicrosoftSync {
  id String @id @default(cuid())

  clientId               String
  projectId              String
  /// Un seul mapping sync par document (RFC-009).
  projectDocumentId      String @unique
  projectMicrosoftLinkId String

  driveId     String
  driveItemId String
  folderPath  String

  syncStatus   MicrosoftSyncStatus @default(PENDING)
  lastPushedAt DateTime?
  lastError    String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectDocument      ProjectDocument      @relation(fields: [projectDocumentId], references: [id], onDelete: Cascade)
  projectMicrosoftLink ProjectMicrosoftLink @relation(fields: [projectMicrosoftLinkId], references: [id], onDelete: Cascade)

  @@index([clientId, projectId])
  @@index([driveItemId])
}

model ProjectTaskMicrosoftSync {
  id String @id @default(cuid())

  clientId               String
  projectId              String
  projectTaskId          String @unique
  projectMicrosoftLinkId String

  plannerTaskId           String
  lastPushedAt            DateTime?
  lastPullFromMicrosoftAt DateTime?
  lastSyncedPlannerEtag   String?
  lastSyncedTaskUpdatedAt DateTime?
  syncStatus              MicrosoftSyncStatus @default(PENDING)
  lastError               String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project              Project              @relation(fields: [projectId], references: [id], onDelete: Cascade)
  projectTask          ProjectTask          @relation(fields: [projectTaskId], references: [id], onDelete: Cascade)
  projectMicrosoftLink ProjectMicrosoftLink @relation(fields: [projectMicrosoftLinkId], references: [id], onDelete: Cascade)

  @@unique([clientId, projectTaskId])
  @@index([clientId, projectId])
  @@index([plannerTaskId])
}

model DirectoryConnection {
  id                      String                @id @default(cuid())
  clientId                String
  name                    String
  providerType            DirectoryProviderType @default(MICROSOFT_GRAPH)
  isActive                Boolean               @default(true)
  isSyncEnabled           Boolean               @default(false)
  lockSyncedCollaborators Boolean               @default(true)
  usersScope              Json?
  metadata                Json?
  createdAt               DateTime              @default(now())
  updatedAt               DateTime              @updatedAt

  client      Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  groupScopes DirectoryGroupScope[]
  syncJobs    DirectorySyncJob[]

  @@index([clientId])
  @@index([clientId, isActive])
}

model DirectoryGroupScope {
  id           String   @id @default(cuid())
  clientId     String
  connectionId String
  groupId      String
  groupName    String?
  isActive     Boolean  @default(true)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  connection DirectoryConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@unique([connectionId, groupId])
  @@index([clientId, connectionId])
}

model DirectorySyncJob {
  id                String                 @id @default(cuid())
  clientId          String
  connectionId      String
  status            DirectorySyncJobStatus
  mode              DirectorySyncMode
  startedAt         DateTime               @default(now())
  finishedAt        DateTime?
  totalFound        Int                    @default(0)
  createdCount      Int                    @default(0)
  updatedCount      Int                    @default(0)
  deactivatedCount  Int                    @default(0)
  skippedCount      Int                    @default(0)
  errorCount        Int                    @default(0)
  summary           Json?
  triggeredByUserId String?

  client     Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  connection DirectoryConnection @relation(fields: [connectionId], references: [id], onDelete: Cascade)

  @@index([clientId, connectionId])
  @@index([startedAt])
}

model Collaborator {
  id                    String                 @id @default(cuid())
  clientId              String
  /// Compte plateforme rattaché à ce client (membre) — identité pilotée par User + synchro membre/ressource.
  userId                String?
  firstName             String?
  lastName              String?
  displayName           String
  email                 String?
  username              String?
  jobTitle              String?
  department            String?
  phone                 String?
  mobile                String?
  employeeNumber        String?
  managerId             String?
  status                CollaboratorStatus     @default(ACTIVE)
  source                CollaboratorSource     @default(MANUAL)
  externalDirectoryId   String?
  externalDirectoryType ExternalDirectoryType?
  externalUsername      String?
  externalRef           String?
  lastSyncedAt          DateTime?
  syncHash              String?
  skills                Json?
  internalNotes         String?
  internalTags          Json?
  assignments           Json?
  metadata              Json?
  createdAt             DateTime               @default(now())
  updatedAt             DateTime               @updatedAt

  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  linkedUser         User?               @relation("CollaboratorLinkedUser", fields: [userId], references: [id], onDelete: SetNull)
  manager            Collaborator?       @relation("CollaboratorManager", fields: [managerId], references: [id], onDelete: SetNull)
  reports            Collaborator[]      @relation("CollaboratorManager")
  collaboratorSkills CollaboratorSkill[]

  @@unique([clientId, externalDirectoryId])
  @@unique([clientId, userId])
  @@index([clientId, email])
  @@index([userId])
  @@index([clientId, username])
  @@index([clientId, source])
  @@index([clientId, externalDirectoryType])
}

/// RFC-TEAM-006 — référentiel types d’activité (taxonomie charge / staffing)
model ActivityType {
  id               String               @id @default(cuid())
  clientId         String
  kind             ActivityTaxonomyKind
  name             String
  code             String?
  description      String?
  sortOrder        Int                  @default(0)
  isDefaultForKind Boolean              @default(false)
  archivedAt       DateTime?
  createdAt        DateTime             @default(now())
  updatedAt        DateTime             @updatedAt

  client              Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resourceTimeEntries ResourceTimeEntry[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, kind])
  @@index([clientId, archivedAt])
}

/// RFC-TEAM-020 / TEAM-009 — temps réalisé (saisie par Resource HUMAN).
model ResourceTimeEntry {
  id             String          @id @default(cuid())
  clientId       String
  resourceId     String
  workDate       DateTime
  durationHours  Decimal         @db.Decimal(8, 2)
  projectId      String?
  activityTypeId String?
  status         TimeEntryStatus @default(DRAFT)
  notes          String?         @db.VarChar(4000)
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  client       Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resource     Resource      @relation(fields: [resourceId], references: [id], onDelete: Restrict)
  project      Project?      @relation(fields: [projectId], references: [id], onDelete: SetNull)
  activityType ActivityType? @relation(fields: [activityTypeId], references: [id], onDelete: SetNull)

  @@index([clientId, resourceId])
  @@index([clientId, workDate])
  @@index([clientId, projectId])
  @@index([clientId, status])
}

/// Verrouillage par mois calendaire UTC (YYYY-MM) : après validation, saisies figées jusqu’au déverrouillage par le manager.
model ResourceTimesheetMonth {
  id                String               @id @default(cuid())
  clientId          String
  resourceId        String
  /// Format `YYYY-MM` (mois UTC cohérent avec les filtres API des entrées).
  yearMonth         String
  status            TimesheetMonthStatus @default(OPEN)
  submittedAt       DateTime?
  submittedByUserId String?
  unlockedAt        DateTime?
  unlockedByUserId  String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([clientId, resourceId, yearMonth])
  @@index([clientId, resourceId])
}

model WorkTeam {
  id             String         @id @default(cuid())
  clientId       String
  name           String
  code           String?
  parentId       String?
  leadResourceId String?
  status         WorkTeamStatus @default(ACTIVE)
  archivedAt     DateTime?
  sortOrder      Int            @default(0)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  client               Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  parent               WorkTeam?              @relation("WorkTeamHierarchy", fields: [parentId], references: [id], onDelete: Restrict)
  children             WorkTeam[]             @relation("WorkTeamHierarchy")
  lead                 Resource?              @relation("WorkTeamLeadResource", fields: [leadResourceId], references: [id], onDelete: SetNull)
  memberships          WorkTeamMembership[]
  managerScopeRootRefs ManagerScopeRootTeam[]

  @@unique([clientId, code])
  @@index([clientId, parentId])
  @@index([clientId, status])
}

model WorkTeamMembership {
  id         String             @id @default(cuid())
  clientId   String
  workTeamId String
  resourceId String
  role       WorkTeamMemberRole @default(MEMBER)
  createdAt  DateTime           @default(now())
  updatedAt  DateTime           @updatedAt

  client   Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  workTeam WorkTeam @relation(fields: [workTeamId], references: [id], onDelete: Cascade)
  resource Resource @relation(fields: [resourceId], references: [id], onDelete: Cascade)

  @@unique([workTeamId, resourceId])
  @@index([clientId, resourceId])
}

model ManagerScopeConfig {
  id                   String           @id @default(cuid())
  clientId             String
  managerResourceId    String           @unique
  mode                 ManagerScopeMode
  includeDirectReports Boolean          @default(true)
  includeTeamSubtree   Boolean          @default(false)
  createdAt            DateTime         @default(now())
  updatedAt            DateTime         @updatedAt

  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  manager   Resource               @relation(fields: [managerResourceId], references: [id], onDelete: Cascade)
  rootTeams ManagerScopeRootTeam[]

  @@index([clientId])
}

model ManagerScopeRootTeam {
  id                   String @id @default(cuid())
  clientId             String
  managerScopeConfigId String
  workTeamId           String

  client   Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  config   ManagerScopeConfig @relation(fields: [managerScopeConfigId], references: [id], onDelete: Cascade)
  workTeam WorkTeam           @relation(fields: [workTeamId], references: [id], onDelete: Cascade)

  @@unique([managerScopeConfigId, workTeamId])
  @@index([clientId, workTeamId])
}

model SkillCategory {
  id             String   @id @default(cuid())
  clientId       String
  name           String
  normalizedName String
  description    String?
  sortOrder      Int      @default(0)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  client Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  skills Skill[]

  @@unique([clientId, normalizedName])
  @@index([clientId])
  @@index([clientId, sortOrder])
}

model Skill {
  id             String              @id @default(cuid())
  clientId       String
  categoryId     String
  name           String
  normalizedName String
  description    String?
  referenceLevel SkillReferenceLevel @default(INTERMEDIATE)
  status         SkillStatus         @default(DRAFT)
  archivedAt     DateTime?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  client             Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  category           SkillCategory       @relation(fields: [categoryId], references: [id], onDelete: Restrict)
  collaboratorSkills CollaboratorSkill[]

  @@unique([clientId, normalizedName])
  @@index([clientId])
  @@index([clientId, categoryId])
  @@index([clientId, status])
}

model CollaboratorSkill {
  id                String                  @id @default(cuid())
  clientId          String
  collaboratorId    String
  skillId           String
  level             SkillReferenceLevel     @default(BEGINNER)
  source            CollaboratorSkillSource @default(SELF_DECLARED)
  comment           String?
  reviewedAt        DateTime?
  validatedByUserId String?
  validatedAt       DateTime?
  createdAt         DateTime                @default(now())
  updatedAt         DateTime                @updatedAt

  client       Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  collaborator Collaborator @relation(fields: [collaboratorId], references: [id], onDelete: Cascade)
  skill        Skill        @relation(fields: [skillId], references: [id], onDelete: Restrict)
  validatedBy  User?        @relation("CollaboratorSkillValidator", fields: [validatedByUserId], references: [id], onDelete: SetNull)

  @@unique([collaboratorId, skillId])
  @@index([clientId])
  @@index([clientId, collaboratorId])
  @@index([clientId, skillId])
  @@index([clientId, level])
  @@index([validatedByUserId])
}
