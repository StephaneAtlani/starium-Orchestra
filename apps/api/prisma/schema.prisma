generator client {
  provider = "prisma-client-js"
}

// Seed: pnpm prisma:seed ou prisma db seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
}

enum ClientUserRole {
  CLIENT_ADMIN
  CLIENT_USER
}

enum ClientUserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

/// Challenge MFA (login ou enrollment) — identifiant public = `id` (challengeId).
enum MfaChallengePurpose {
  LOGIN
  ENROLL
}

/// Canal principal du challenge (fallback email stocke le hash OTP dans `otpCodeHash`).
enum MfaChallengeChannel {
  TOTP
  EMAIL
}

enum TaxDisplayMode {
  HT
  TTC
}

enum TaxInputMode {
  HT
  TTC
}

enum BudgetTaxMode {
  HT
  TTC
}

model HealthCheck {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
}

model Client {
  id                         String                    @id @default(cuid())
  name                       String
  slug                       String                    @unique
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  budgetAccountingEnabled    Boolean                   @default(false)
  taxDisplayMode            TaxDisplayMode           @default(HT)
  taxInputMode              TaxInputMode             @default(HT)
  defaultTaxRate            Decimal?                  @db.Decimal(5, 2)
  clientUsers                ClientUser[]
  clientModules              ClientModule[]
  roles                      Role[]
  auditLogs                  AuditLog[]
  budgetExercises            BudgetExercise[]
  budgets                    Budget[]
  budgetEnvelopes            BudgetEnvelope[]
  budgetLines                BudgetLine[]
  financialAllocations       FinancialAllocation[]
  financialEvents            FinancialEvent[]
  suppliers                  Supplier[]
  purchaseOrders             PurchaseOrder[]
  invoices                   Invoice[]
  budgetSnapshots            BudgetSnapshot[]
  budgetReallocations        BudgetReallocation[]
  budgetImportMappings       BudgetImportMapping[]
  budgetImportJobs           BudgetImportJob[]
  budgetImportRowLinks       BudgetImportRowLink[]
  budgetVersionSets          BudgetVersionSet[]
  generalLedgerAccounts      GeneralLedgerAccount[]
  analyticalLedgerAccounts   AnalyticalLedgerAccount[]
  costCenters                CostCenter[]
  budgetLineCostCenterSplits BudgetLineCostCenterSplit[]
  projects         Project[]
  projectTasks     ProjectTask[]
  projectRisks     ProjectRisk[]
  projectMilestones  ProjectMilestone[]
  projectBudgetLinks ProjectBudgetLink[]
  projectTeamRoles   ProjectTeamRole[]
  projectTeamMembers ProjectTeamMember[]
  projectSheetDecisionSnapshots ProjectSheetDecisionSnapshot[]
  projectReviews                ProjectReview[]
  projectReviewParticipants     ProjectReviewParticipant[]
  projectReviewDecisions        ProjectReviewDecision[]
  projectReviewActionItems      ProjectReviewActionItem[]
  projectActivities             ProjectActivity[]
  budgetLinePlanningMonths   BudgetLinePlanningMonth[]
  budgetLinePlanningScenarios BudgetLinePlanningScenario[]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  /// Service / département (profil modifiable par l’utilisateur)
  department    String?
  /// Intitulé de poste
  jobTitle      String?
  /// Société / employeur affiché
  company       String?
  /// Bureau / localisation
  office        String?
  /// MIME image (ex. image/jpeg) si une photo est enregistrée sur disque
  avatarMimeType String?
  platformRole  PlatformRole?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clientUsers   ClientUser[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  securityLogs  SecurityLog[]
  userMfa         UserMfa?
  mfaChallenges   MfaChallenge[]
  trustedDevices  TrustedDevice[]
  ownedBudgets Budget[]           @relation("OwnedBudgets")
  createdBudgetSnapshots BudgetSnapshot[]
  budgetReallocationsCreated BudgetReallocation[]
  createdBudgetImportMappings BudgetImportMapping[]
  createdBudgetImportJobs    BudgetImportJob[]
  sponsoredProjects          Project[]           @relation("ProjectSponsor")
  ownedProjects              Project[]           @relation("ProjectOwner")
  ownedProjectTasks          ProjectTask[]       @relation("ProjectTaskOwner")
  createdProjectTasks        ProjectTask[]       @relation("ProjectTaskCreatedBy")
  updatedProjectTasks        ProjectTask[]       @relation("ProjectTaskUpdatedBy")
  ownedProjectMilestones     ProjectMilestone[]  @relation("ProjectMilestoneOwner")
  createdProjectMilestones   ProjectMilestone[]  @relation("ProjectMilestoneCreatedBy")
  updatedProjectMilestones   ProjectMilestone[]  @relation("ProjectMilestoneUpdatedBy")
  ownedProjectActivities     ProjectActivity[]   @relation("ProjectActivityOwner")
  createdProjectActivities   ProjectActivity[]   @relation("ProjectActivityCreatedBy")
  updatedProjectActivities   ProjectActivity[]   @relation("ProjectActivityUpdatedBy")
  ownedProjectRisks          ProjectRisk[]
  projectTeamMembers         ProjectTeamMember[]
  createdProjectSheetDecisionSnapshots ProjectSheetDecisionSnapshot[] @relation("ProjectSheetDecisionSnapshotCreatedBy")
  facilitatedProjectReviews          ProjectReview[]                  @relation("ProjectReviewFacilitator")
  finalizedProjectReviews            ProjectReview[]                  @relation("ProjectReviewFinalizedBy")
  projectReviewParticipants          ProjectReviewParticipant[]
}

model ClientUser {
  id        String           @id @default(cuid())
  userId    String
  clientId  String
  role      ClientUserRole
  status    ClientUserStatus @default(ACTIVE)
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
  @@index([userId])
}

/// Catalogue global des modules (budgets, projects, contracts, etc.).
model Module {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  permissions   Permission[]
  clientModules ClientModule[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Activation d'un module pour un client donné.
model ClientModule {
  id        String             @id @default(cuid())
  clientId  String
  moduleId  String
  status    ClientModuleStatus @default(ENABLED)
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([clientId, moduleId])
  @@index([clientId])
  @@index([moduleId])
}

/// Rôle métier client (scopé par client).
model Role {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  description    String?
  isSystem       Boolean         @default(false)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles      UserRole[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([clientId, name])
  @@index([clientId])
}

/// Permission unitaire globale (<module>.<action>).
model Permission {
  id             String          @id @default(cuid())
  code           String          @unique
  label          String
  description    String?
  moduleId       String
  module         Module          @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([moduleId])
}

/// Liaison N:N rôle ↔ permission.
model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

/// Liaison utilisateur ↔ rôle métier (le client est porté par Role.clientId).
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

enum ClientModuleStatus {
  ENABLED
  DISABLED
}

// --- Projects MVP (RFC-PROJ-001) ---

/** Projet structuré vs activité de suivi plus légère (même entité `Project` côté SI). */
enum ProjectKind {
  PROJECT
  ACTIVITY
}

enum ProjectType {
  TRANSFORMATION
  INFRASTRUCTURE
  APPLICATION
  CYBERSECURITY
  COMPLIANCE
  ORGANIZATION
  PROCUREMENT
  GOVERNANCE
}

enum ProjectStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectCriticality {
  LOW
  MEDIUM
  HIGH
}

enum ProjectTaskStatus {
  DRAFT
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

/// RFC-PROJ-011 — dépendance simple entre tâches (MVP)
enum ProjectTaskDependencyType {
  FINISH_TO_START
  START_TO_START
  FINISH_TO_FINISH
}

/// RFC-PROJ-011 — activité dérivée d’une tâche
enum ProjectActivityFrequency {
  DAILY
  WEEKLY
  MONTHLY
  QUARTERLY
  YEARLY
  CUSTOM
}

enum ProjectActivityStatus {
  ACTIVE
  PAUSED
  COMPLETED
  CANCELLED
}

enum ProjectRiskStatus {
  OPEN
  MITIGATED
  CLOSED
  ACCEPTED
}

enum ProjectRiskProbability {
  LOW
  MEDIUM
  HIGH
}

enum ProjectRiskImpact {
  LOW
  MEDIUM
  HIGH
}

enum ProjectMilestoneStatus {
  PLANNED
  ACHIEVED
  DELAYED
  CANCELLED
}

/** RFC-PROJ-010 — liaison projet ↔ ligne budgétaire */
enum ProjectBudgetAllocationType {
  FULL
  PERCENTAGE
  FIXED
}

/** RFC-PROJ-012 — fiche projet décisionnelle */
enum ProjectRiskLevel {
  LOW
  MEDIUM
  HIGH
}

enum ProjectArbitrationStatus {
  DRAFT
  TO_REVIEW
  VALIDATED
  REJECTED
}

/** Statut par niveau d’arbitrage (Métier → Comité → Sponsor/CODIR). */
enum ProjectArbitrationLevelStatus {
  BROUILLON
  EN_COURS
  /// Dossier transmis ; en attente de décision (visa) avant validation ou refus.
  SOUMIS_VALIDATION
  VALIDE
  REFUSE
}

/** Recommandation saisie par le COPIL / COPRO (pas dérivée automatiquement des indicateurs). */
enum ProjectCopilRecommendation {
  NOT_SET
  POURSUIVRE
  NE_PAS_ENGAGER
  SOUS_RESERVE
  REPORTER
  AJUSTER_CADRAGE
}

/** Instantané fiche projet lors d’une validation d’arbitrage (niveau passé à VALIDE). */
enum ProjectSheetDecisionLevel {
  METIER
  COMITE
  CODIR
}

/** Rôle catalogue équipe projet — aligné sur Project.sponsorUserId / ownerUserId lorsque renseigné. */
enum ProjectTeamRoleSystemKind {
  SPONSOR
  OWNER
}

/// Interne (client / équipe) vs externe (prestataire, partenaire) pour les noms libres.
enum ProjectTeamMemberAffiliation {
  INTERNAL
  EXTERNAL
}

/// RFC-PROJ-013 — point projet (COPIL / COPRO / …)
enum ProjectReviewType {
  COPIL
  COPRO
  CODIR_REVIEW
  RISK_REVIEW
  MILESTONE_REVIEW
  AD_HOC
}

enum ProjectReviewStatus {
  DRAFT
  FINALIZED
  CANCELLED
}

model Project {
  id        String  @id @default(cuid())
  clientId  String
  name      String
  code      String
  description String?

  kind         ProjectKind @default(PROJECT)
  type         ProjectType
  status       ProjectStatus
  priority     ProjectPriority

  sponsorUserId String?
  ownerUserId   String?
  /// Responsable hors compte (dénormalisé ; aligné avec entrée équipe « Responsable » nom libre).
  ownerFreeLabel    String?                       @db.VarChar(200)
  ownerAffiliation  ProjectTeamMemberAffiliation?

  startDate      DateTime?
  targetEndDate  DateTime?
  actualEndDate  DateTime?

  criticality     ProjectCriticality
  progressPercent Int?

  targetBudgetAmount Decimal? @db.Decimal(18, 2)
  pilotNotes         String?

  businessValueScore   Int?
  strategicAlignment   Int?
  urgencyScore         Int?

  estimatedCost     Decimal? @db.Decimal(18, 2)
  estimatedGain     Decimal? @db.Decimal(18, 2)
  roi               Decimal? @db.Decimal(10, 2)
  riskLevel         ProjectRiskLevel?
  /// Réponse au risque : traitement, mitigation, plan d’action (texte libre, fiche CODIR)
  riskResponse      String?
  priorityScore     Decimal? @db.Decimal(5, 2)
  /// Dérivé des trois niveaux (rétrocompat lecture / exports).
  arbitrationStatus ProjectArbitrationStatus?
  arbitrationMetierStatus  ProjectArbitrationLevelStatus @default(BROUILLON)
  arbitrationComiteStatus    ProjectArbitrationLevelStatus?
  arbitrationCodirStatus     ProjectArbitrationLevelStatus?
  arbitrationMetierRefusalNote  String? @db.VarChar(2000)
  arbitrationComiteRefusalNote  String? @db.VarChar(2000)
  arbitrationCodirRefusalNote   String? @db.VarChar(2000)
  copilRecommendation ProjectCopilRecommendation @default(NOT_SET)
  /// Commentaire libre associé à la position COPIL (visible sur demande à l’UI).
  copilRecommendationNote String? @db.VarChar(4000)

  /// Cadrage OQQCQPC (fiche projet)
  cadreLocation String? @db.VarChar(500)
  cadreQui      String? @db.VarChar(500)

  /// Équipes / directions impliquées (texte libre, fiche projet)
  involvedTeams String? @db.VarChar(2000)

  /// RFC-PROJ-012 — objectif métier (texte MVP)
  businessProblem   String?
  businessBenefits  String?
  /// KPI de succès — liste de lignes (JSON string[])
  businessSuccessKpis Json?

  /// SWOT / TOWS — JSON (tableaux de strings ; contraintes en DTO)
  swotStrengths     Json?
  swotWeaknesses    Json?
  swotOpportunities Json?
  swotThreats       Json?
  towsActions       Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sponsor  User?  @relation("ProjectSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  owner    User?  @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  tasks       ProjectTask[]
  risks       ProjectRisk[]
  milestones  ProjectMilestone[]
  activities  ProjectActivity[]
  budgetLinks ProjectBudgetLink[]
  teamMembers ProjectTeamMember[]
  sheetDecisionSnapshots ProjectSheetDecisionSnapshot[]
  projectReviews         ProjectReview[]
  projectReviewActionItems ProjectReviewActionItem[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, status])
  @@index([clientId, kind])
  @@index([targetEndDate])
}

/// Historique des décisions — snapshot de fiche projet au passage d’un niveau d’arbitrage à VALIDE.
model ProjectSheetDecisionSnapshot {
  id        String   @id @default(cuid())
  clientId  String
  projectId String
  createdAt DateTime @default(now())
  createdByUserId String?
  decisionLevel ProjectSheetDecisionLevel
  sheetPayload Json

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  createdBy User? @relation("ProjectSheetDecisionSnapshotCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)

  @@index([clientId, projectId, createdAt])
  @@index([projectId, createdAt])
}

/// RFC-PROJ-013 — point projet (COPIL-COPRO), historisé.
model ProjectReview {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  reviewDate   DateTime
  reviewType   ProjectReviewType
  status       ProjectReviewStatus @default(DRAFT)

  title             String?
  executiveSummary  String?
  contentPayload    Json?

  facilitatorUserId String?
  finalizedAt       DateTime?
  finalizedByUserId String?

  nextReviewDate DateTime?

  snapshotPayload Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client      Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project     Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  facilitator User?   @relation("ProjectReviewFacilitator", fields: [facilitatorUserId], references: [id], onDelete: SetNull)
  finalizedBy User?   @relation("ProjectReviewFinalizedBy", fields: [finalizedByUserId], references: [id], onDelete: SetNull)

  participants ProjectReviewParticipant[]
  decisions    ProjectReviewDecision[]
  actionItems  ProjectReviewActionItem[]

  @@index([clientId, projectId, reviewDate])
  @@index([clientId, projectId, status])
  @@index([projectId, reviewDate])
}

model ProjectReviewParticipant {
  id              String @id @default(cuid())
  clientId        String
  projectReviewId String

  userId      String?
  displayName String?

  attended   Boolean @default(true)
  isRequired Boolean @default(false)

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectReview ProjectReview @relation(fields: [projectReviewId], references: [id], onDelete: Cascade)
  user          User?         @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectReviewId])
}

model ProjectReviewDecision {
  id              String @id @default(cuid())
  clientId        String
  projectReviewId String

  title       String
  description String?

  createdAt DateTime @default(now())

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectReview ProjectReview @relation(fields: [projectReviewId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectReviewId])
}

model ProjectReviewActionItem {
  id              String @id @default(cuid())
  clientId        String
  projectReviewId String
  projectId       String

  title        String
  status       ProjectTaskStatus
  dueDate      DateTime?
  linkedTaskId String?

  client        Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  projectReview ProjectReview @relation(fields: [projectReviewId], references: [id], onDelete: Cascade)
  project       Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedTask    ProjectTask?  @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([clientId, projectId])
  @@index([projectReviewId])
}

/// Catalogue des rôles d’équipe projet (par client).
model ProjectTeamRole {
  id          String   @id @default(cuid())
  clientId    String
  name        String   @db.VarChar(200)
  sortOrder   Int      @default(0)
  /// Si défini, synchronisé avec Project.sponsorUserId ou ownerUserId (une personne « officielle »).
  systemKind  ProjectTeamRoleSystemKind?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  members ProjectTeamMember[]

  @@unique([clientId, name])
  @@index([clientId])
}

/// Membre d’équipe projet : utilisateur plateforme ou nom libre (prestataire / contact externe).
model ProjectTeamMember {
  id        String @id @default(cuid())
  clientId  String
  projectId String
  roleId    String
  /// Compte Starium du client ; vide si entrée libre uniquement.
  userId    String?
  /// Nom affiché lorsqu’il n’y a pas de `userId` (personne hors plateforme).
  freeLabel String? @db.VarChar(200)
  /// Interne vs externe (surtout pour les noms libres).
  affiliation ProjectTeamMemberAffiliation?
  /// Clé d’unicité : `u:<userId>` ou `n:<normalisation du nom>` pour les entrées libres.
  identityKey String @db.VarChar(150)

  createdAt DateTime @default(now())

  client  Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project         @relation(fields: [projectId], references: [id], onDelete: Cascade)
  role    ProjectTeamRole @relation(fields: [roleId], references: [id], onDelete: Restrict)
  user    User?           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([projectId, roleId, identityKey])
  @@index([clientId])
  @@index([clientId, projectId])
  @@index([roleId])
}

model ProjectBudgetLink {
  id             String                      @id @default(cuid())
  clientId       String
  projectId      String
  budgetLineId   String
  allocationType ProjectBudgetAllocationType
  percentage     Decimal?                    @db.Decimal(5, 2)
  amount         Decimal?                    @db.Decimal(18, 2)
  createdAt      DateTime                    @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project    @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Restrict)

  @@unique([projectId, budgetLineId])
  @@index([clientId])
}

/// RFC-PROJ-011 — tâche projet planifiable (Gantt-ready)
model ProjectTask {
  id              String @id @default(cuid())
  clientId        String
  projectId       String

  parentTaskId    String?
  dependsOnTaskId String?

  code        String?
  name        String
  description String?

  status   ProjectTaskStatus   @default(TODO)
  priority ProjectTaskPriority @default(MEDIUM)
  progress Int                 @default(0)

  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  sortOrder Int @default(0)

  dependencyType ProjectTaskDependencyType?

  ownerUserId   String?
  budgetLineId  String?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLine BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  parentTask    ProjectTask?  @relation("ProjectTaskHierarchy", fields: [parentTaskId], references: [id], onDelete: SetNull)
  childTasks    ProjectTask[]   @relation("ProjectTaskHierarchy")
  dependsOnTask ProjectTask?  @relation("ProjectTaskDependency", fields: [dependsOnTaskId], references: [id], onDelete: SetNull)
  dependentTasks ProjectTask[]  @relation("ProjectTaskDependency")

  ownerUser          User? @relation("ProjectTaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser      User? @relation("ProjectTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser      User? @relation("ProjectTaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  activities               ProjectActivity[]
  milestones               ProjectMilestone[]
  projectReviewActionItems ProjectReviewActionItem[]

  @@index([clientId])
  @@index([projectId])
  @@index([clientId, projectId])
  @@index([parentTaskId])
  @@index([dependsOnTaskId])
  @@index([status])
  @@index([priority])
  @@index([plannedStartDate])
  @@index([plannedEndDate])
}

model ProjectRisk {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  title       String
  description String?

  probability ProjectRiskProbability
  impact      ProjectRiskImpact

  actionPlan   String?
  ownerUserId  String?

  status     ProjectRiskStatus
  reviewDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

/// RFC-PROJ-011 — jalon (sans durée)
model ProjectMilestone {
  id           String @id @default(cuid())
  clientId     String
  projectId    String
  linkedTaskId String?

  code        String?
  name        String
  description String?

  status       ProjectMilestoneStatus @default(PLANNED)
  targetDate   DateTime
  achievedDate DateTime?

  sortOrder Int @default(0)

  ownerUserId String?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  linkedTask ProjectTask? @relation(fields: [linkedTaskId], references: [id], onDelete: SetNull)

  ownerUser     User? @relation("ProjectMilestoneOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("ProjectMilestoneCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProjectMilestoneUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([linkedTaskId])
  @@index([targetDate])
  @@index([status])
}

/// RFC-PROJ-011 — activité dérivée d’une tâche (hors Gantt MVP)
model ProjectActivity {
  id           String @id @default(cuid())
  clientId     String
  projectId    String
  sourceTaskId String

  name        String
  description String?

  status    ProjectActivityStatus    @default(ACTIVE)
  frequency ProjectActivityFrequency
  customRrule String?

  nextExecutionDate DateTime?
  lastExecutionDate DateTime?

  ownerUserId  String?
  budgetLineId String?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project    Project     @relation(fields: [projectId], references: [id], onDelete: Cascade)
  sourceTask ProjectTask @relation(fields: [sourceTaskId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine? @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)

  ownerUser     User? @relation("ProjectActivityOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("ProjectActivityCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProjectActivityUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
  @@index([sourceTaskId])
  @@index([status])
  @@index([nextExecutionDate])
}

// --- Budget MVP (RFC-015-1A) ---

enum BudgetExerciseStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum BudgetEnvelopeStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum BudgetEnvelopeType {
  RUN
  BUILD
  TRANSVERSE
}

enum BudgetLineStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

// --- Budget Versioning (RFC-019) ---

enum BudgetVersionKind {
  BASELINE
  REVISION
}

enum BudgetVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum ExpenseType {
  OPEX
  CAPEX
}

enum FinancialSourceType {
  PROJECT
  ACTIVITY
  SUPPLIER
  CONTRACT
  LICENSE
  ORDER
  TEAM_ASSIGNMENT
  APPLICATION
  ASSET
  MANUAL
  PURCHASE_ORDER
  INVOICE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  APPROVED
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CANCELLED
}

enum InvoiceStatus {
  RECEIVED
  VALIDATED
  PAID
  CANCELLED
}

enum AllocationType {
  PLANNED
  RESERVED
  COMMITTED
  CONSUMED
  FORECAST
  REALLOCATED
  CANCELLED
}

enum FinancialEventType {
  LINE_CREATED
  BUDGET_INITIALIZED
  ALLOCATION_ADDED
  ALLOCATION_UPDATED
  COMMITMENT_REGISTERED
  CONSUMPTION_REGISTERED
  FORECAST_UPDATED
  REALLOCATION_DONE
  CANCELLATION
  ADJUSTMENT
}

model BudgetExercise {
  id        String               @id @default(cuid())
  clientId  String
  name      String
  code      String
  startDate DateTime
  endDate   DateTime
  status    BudgetExerciseStatus @default(DRAFT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgets   Budget[]
  budgetSnapshots BudgetSnapshot[]
  budgetVersionSets BudgetVersionSet[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([status])
}

model BudgetVersionSet {
  id               String    @id @default(cuid())
  clientId         String
  exerciseId       String
  code            String
  name            String
  description     String?
  baselineBudgetId String?   @unique
  activeBudgetId   String?    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise        BudgetExercise  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  versions        Budget[]        @relation("VersionSetVersions")
  baselineBudget  Budget?         @relation("VersionSetBaseline", fields: [baselineBudgetId], references: [id], onDelete: SetNull)
  activeBudget    Budget?         @relation("VersionSetActive", fields: [activeBudgetId], references: [id], onDelete: SetNull)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([exerciseId])
}

model Budget {
  id            String       @id @default(cuid())
  clientId      String
  exerciseId    String
  name          String
  code          String
  description   String?
  currency      String
  status        BudgetStatus @default(DRAFT)
  taxMode       BudgetTaxMode @default(HT)
  defaultTaxRate Decimal?    @db.Decimal(5, 2)
  ownerUserId   String?
  versionSetId  String?
  versionNumber Int?
  versionLabel  String?
  versionKind   BudgetVersionKind?
  versionStatus BudgetVersionStatus?
  parentBudgetId String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  isVersioned   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise      BudgetExercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  owner         User?        @relation("OwnedBudgets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  versionSet    BudgetVersionSet? @relation("VersionSetVersions", fields: [versionSetId], references: [id], onDelete: SetNull)
  parentBudget  Budget?      @relation("BudgetVersionParent", fields: [parentBudgetId], references: [id], onDelete: SetNull)
  childVersions Budget[]     @relation("BudgetVersionParent")
  baselineForSet BudgetVersionSet? @relation("VersionSetBaseline")
  activeForSet   BudgetVersionSet? @relation("VersionSetActive")
  envelopes     BudgetEnvelope[]
  budgetLines   BudgetLine[]
  budgetSnapshots BudgetSnapshot[]
  budgetReallocations BudgetReallocation[]
  budgetImportJobs    BudgetImportJob[]

  @@unique([clientId, code])
  @@unique([versionSetId, versionNumber])
  @@index([clientId])
  @@index([exerciseId])
  @@index([status])
  @@index([clientId, versionSetId])
  @@index([clientId, versionStatus])
  @@index([clientId, versionKind])
}

model BudgetEnvelope {
  id          String             @id @default(cuid())
  clientId    String
  budgetId    String
  parentId    String?
  name        String
  code        String
  type        BudgetEnvelopeType
  description String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  status      BudgetEnvelopeStatus @default(ACTIVE)
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget      Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent      BudgetEnvelope?    @relation("EnvelopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BudgetEnvelope[]   @relation("EnvelopeHierarchy")
  budgetLines BudgetLine[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([parentId])
  @@index([status])
}

enum BudgetLineAllocationScope {
  ENTERPRISE
  ANALYTICAL
}

enum BudgetLinePlanningMode {
  MANUAL
  ANNUAL_SPREAD
  QUARTERLY_SPREAD
  ONE_SHOT
  GROWTH
  CALCULATED
}

model GeneralLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model AnalyticalLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model CostCenter {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  splits      BudgetLineCostCenterSplit[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model BudgetLine {
  id                       String                     @id @default(cuid())
  clientId                 String
  budgetId                 String
  envelopeId               String
  code                     String
  name                     String
  description              String?
  expenseType              ExpenseType
  status                   BudgetLineStatus           @default(DRAFT)
  currency                 String
  taxRate                  Decimal?                   @db.Decimal(5, 2)
  initialAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  revisedAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  forecastAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  committedAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  consumedAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  remainingAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  generalLedgerAccountId   String?
  analyticalLedgerAccountId String?
  allocationScope          BudgetLineAllocationScope  @default(ENTERPRISE)
  planningMode             BudgetLinePlanningMode?
  planningTotalAmount      Decimal?                   @db.Decimal(18, 2)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  client                   Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget                   Budget                    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  envelope                 BudgetEnvelope            @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  generalLedgerAccount     GeneralLedgerAccount?     @relation(fields: [generalLedgerAccountId], references: [id], onDelete: Restrict)
  analyticalLedgerAccount  AnalyticalLedgerAccount?  @relation(fields: [analyticalLedgerAccountId], references: [id], onDelete: SetNull)
  costCenterSplits         BudgetLineCostCenterSplit[]
  allocations               FinancialAllocation[]
  financialEvents           FinancialEvent[]
  purchaseOrders            PurchaseOrder[]
  invoices                  Invoice[]
  reallocationsAsSource     BudgetReallocation[]      @relation("ReallocationSource")
  reallocationsAsTarget     BudgetReallocation[]      @relation("ReallocationTarget")
  projectBudgetLinks        ProjectBudgetLink[]
  projectTasks              ProjectTask[]
  projectActivities         ProjectActivity[]
  planningMonths            BudgetLinePlanningMonth[]
  planningScenarios         BudgetLinePlanningScenario[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([envelopeId])
  @@index([status])
}

model BudgetLinePlanningMonth {
  id           String   @id @default(cuid())
  clientId     String
  budgetLineId String
  monthIndex   Int
  amount       Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine  BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@unique([budgetLineId, monthIndex])
  @@index([clientId, budgetLineId])
}

model BudgetLinePlanningScenario {
  id           String                 @id @default(cuid())
  clientId     String
  budgetLineId String
  mode         BudgetLinePlanningMode
  inputJson    Json
  createdById  String?
  createdAt    DateTime               @default(now())

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine  BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId, budgetLineId, createdAt])
}

model BudgetLineCostCenterSplit {
  id           String   @id @default(cuid())
  clientId     String
  budgetLineId String
  costCenterId String
  percentage   Decimal  @db.Decimal(5, 2)
  createdAt    DateTime @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Restrict)

  @@unique([budgetLineId, costCenterId])
  @@index([budgetLineId])
  @@index([clientId, budgetLineId])
  @@index([clientId, costCenterId])
}

enum BudgetSnapshotStatus {
  ACTIVE
  ARCHIVED
}

model BudgetSnapshot {
  id                   String                @id @default(cuid())
  clientId             String
  budgetId             String
  exerciseId           String
  name                 String
  code                 String
  description          String?
  snapshotDate         DateTime
  status               BudgetSnapshotStatus   @default(ACTIVE)

  budgetName           String
  budgetCode           String?
  budgetCurrency       String
  budgetStatus         BudgetStatus

  totalInitialAmount   Decimal               @db.Decimal(18, 2)
  totalRevisedAmount   Decimal               @db.Decimal(18, 2)
  totalForecastAmount  Decimal               @db.Decimal(18, 2)
  totalCommittedAmount Decimal               @db.Decimal(18, 2)
  totalConsumedAmount  Decimal               @db.Decimal(18, 2)
  totalRemainingAmount Decimal               @db.Decimal(18, 2)

  createdByUserId      String?
  createdAt            DateTime              @default(now())

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budget                Budget                @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  exercise              BudgetExercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  createdByUser         User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                 BudgetSnapshotLine[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([exerciseId])
  @@index([snapshotDate])
  @@index([clientId, budgetId])
}

model BudgetSnapshotLine {
  id               String   @id @default(cuid())
  snapshotId       String
  clientId         String

  budgetLineId     String
  budgetId         String
  envelopeId       String?

  envelopeName     String?
  envelopeCode     String?
  envelopeType     BudgetEnvelopeType?

  lineCode         String
  lineName         String
  expenseType      ExpenseType
  currency         String
  lineStatus       BudgetLineStatus

  initialAmount    Decimal  @db.Decimal(18, 2)
  revisedAmount    Decimal  @db.Decimal(18, 2)
  forecastAmount   Decimal  @db.Decimal(18, 2)
  committedAmount  Decimal  @db.Decimal(18, 2)
  consumedAmount   Decimal  @db.Decimal(18, 2)
  remainingAmount  Decimal  @db.Decimal(18, 2)

  createdAt        DateTime @default(now())

  snapshot         BudgetSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([clientId])
  @@index([budgetLineId])
  @@index([budgetId])
  @@index([envelopeId])
}

model FinancialAllocation {
  id             String         @id @default(cuid())
  clientId       String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String
  allocationType AllocationType
  allocatedAmount Decimal       @db.Decimal(18, 2)
  currency      String
  effectiveDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([allocationType])
}

model FinancialEvent {
  id            String              @id @default(cuid())
  clientId      String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String?
  eventType     FinancialEventType
  amount        Decimal             @db.Decimal(18, 2)
  amountHt      Decimal             @db.Decimal(18, 2)
  taxRate       Decimal?            @db.Decimal(5, 2)
  taxAmount     Decimal?            @db.Decimal(18, 2)
  amountTtc     Decimal?            @db.Decimal(18, 2)
  currency      String
  eventDate     DateTime
  label         String
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine          @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([eventType])
  @@index([eventDate])
}

model BudgetReallocation {
  id            String    @id @default(cuid())
  clientId      String
  budgetId      String
  sourceLineId  String
  targetLineId  String
  amount        Decimal   @db.Decimal(18, 2)
  currency      String
  reason        String?
  createdById   String?
  createdAt     DateTime  @default(now())

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget        Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  sourceLine    BudgetLine @relation("ReallocationSource", fields: [sourceLineId], references: [id], onDelete: Restrict)
  targetLine    BudgetLine @relation("ReallocationTarget", fields: [targetLineId], references: [id], onDelete: Restrict)
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([budgetId])
  @@index([sourceLineId])
  @@index([targetLineId])
  @@index([createdAt])
}

model Supplier {
  id             String         @id @default(cuid())
  clientId       String
  name           String
  code           String?
  siret          String?
  vatNumber      String?
  status         SupplierStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([clientId, name])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  clientId     String
  supplierId   String
  budgetLineId String?
  reference    String
  label        String
  amountHt     Decimal             @db.Decimal(18, 2)
  taxRate      Decimal?            @db.Decimal(5, 2)
  taxAmount    Decimal?            @db.Decimal(18, 2)
  amountTtc    Decimal?            @db.Decimal(18, 2)
  orderDate    DateTime
  status       PurchaseOrderStatus @default(APPROVED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  budgetLine   BudgetLine?         @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@unique([clientId, reference])
  @@index([clientId])
  @@index([supplierId])
  @@index([budgetLineId])
  @@index([clientId, supplierId])
}

model Invoice {
  id              String        @id @default(cuid())
  clientId        String
  supplierId      String
  budgetLineId    String?
  purchaseOrderId String?
  invoiceNumber   String
  label           String
  amountHt        Decimal       @db.Decimal(18, 2)
  taxRate         Decimal?      @db.Decimal(5, 2)
  taxAmount       Decimal?      @db.Decimal(18, 2)
  amountTtc       Decimal?      @db.Decimal(18, 2)
  invoiceDate     DateTime
  status          InvoiceStatus @default(VALIDATED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  budgetLine      BudgetLine?   @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@unique([clientId, invoiceNumber, supplierId])
  @@index([clientId])
  @@index([supplierId])
  @@index([budgetLineId])
  @@index([clientId, supplierId])
}

// --- Budget Import (RFC-018) ---

enum BudgetImportSourceType {
  CSV
  XLSX
}

enum BudgetImportEntityType {
  BUDGET_LINES
}

enum BudgetImportTargetEntityType {
  BUDGET_LINE
}

enum BudgetImportJobStatus {
  ANALYZED
  PREVIEWED
  RUNNING
  COMPLETED
  FAILED
}

enum BudgetImportMode {
  CREATE_ONLY
  UPSERT
  UPDATE_ONLY
}

model BudgetImportMapping {
  id              String                  @id @default(cuid())
  clientId        String
  name            String
  description     String?
  sourceType      BudgetImportSourceType
  entityType      BudgetImportEntityType   @default(BUDGET_LINES)
  sheetName       String?
  headerRowIndex  Int                      @default(1)
  mappingConfig   Json
  optionsConfig   Json?
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  jobs      BudgetImportJob[]

  @@index([clientId])
}

model BudgetImportJob {
  id            String                @id @default(cuid())
  clientId      String
  budgetId      String
  mappingId     String?
  fileName      String
  sourceType    BudgetImportSourceType
  status        BudgetImportJobStatus
  importMode    BudgetImportMode
  totalRows     Int                   @default(0)
  createdRows   Int                   @default(0)
  updatedRows   Int                   @default(0)
  skippedRows   Int                   @default(0)
  errorRows     Int                   @default(0)
  summary       Json?
  createdById   String?
  createdAt     DateTime              @default(now())

  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget    Budget                 @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  mapping   BudgetImportMapping?   @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  createdBy User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rowLinks  BudgetImportRowLink[]

  @@index([clientId, budgetId])
  @@index([mappingId])
}

model BudgetImportRowLink {
  id               String                       @id @default(cuid())
  clientId         String
  budgetId         String
  importJobId      String
  targetEntityType BudgetImportTargetEntityType @default(BUDGET_LINE)
  targetEntityId   String
  sourceRowNumber  Int?
  externalId       String?
  compositeHash    String?
  fingerprintData  Json?
  createdAt        DateTime                    @default(now())

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importJob BudgetImportJob  @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([clientId, budgetId, targetEntityType, targetEntityId])
  @@index([clientId, budgetId, externalId])
  @@index([clientId, budgetId, compositeHash])
}

// --- End Budget MVP ---

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  revokedAt DateTime?
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

/// Paramètres 2FA TOTP par utilisateur (un seul enregistrement par user).
model UserMfa {
  id        String    @id @default(cuid())
  userId    String    @unique
  user      User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  /// Secret TOTP chiffré (AES-256-GCM) — présent dès l’init d’enrollment ou après activation
  totpSecretEncrypted String?
  totpPending         Boolean   @default(false)
  totpEnabledAt       DateTime?
  /// Codes de secours : tableau JSON de hash bcrypt (jamais en clair)
  backupCodesHashes   Json?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt
}

model MfaChallenge {
  id           String               @id @default(cuid())
  userId       String
  user         User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  purpose      MfaChallengePurpose
  channel      MfaChallengeChannel  @default(TOTP)
  /// OTP email (fallback) : hash du code à usage unique
  otpCodeHash  String?
  emailSentAt  DateTime?
  expiresAt    DateTime
  attemptCount Int                  @default(0)
  consumedAt   DateTime?
  createdAt    DateTime             @default(now())

  @@index([userId])
  @@index([expiresAt])
}

/// Jeton opaque (hash stocké) : « appareil de confiance » pour éviter la 2FA à chaque login (durée limitée).
model TrustedDevice {
  id         String   @id @default(cuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  tokenHash  String   @unique
  expiresAt  DateTime
  lastUsedAt DateTime @default(now())
  userAgent  String?
  ipAddress  String?
  createdAt  DateTime @default(now())

  @@index([userId])
  @@index([expiresAt])
}

model AuditLog {
  id String @id @default(cuid())

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AuditLogArchive {
  id String @id

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType])
}

model SecurityLog {
  id String @id @default(cuid())

  event String

  userId String?
  email  String?

  success Boolean
  reason  String?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}
