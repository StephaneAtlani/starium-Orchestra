generator client {
  provider = "prisma-client-js"
}

// Seed: pnpm prisma:seed ou prisma db seed

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum PlatformRole {
  PLATFORM_ADMIN
}

enum ClientUserRole {
  CLIENT_ADMIN
  CLIENT_USER
}

enum ClientUserStatus {
  ACTIVE
  SUSPENDED
  INVITED
}

enum TaxDisplayMode {
  HT
  TTC
}

enum TaxInputMode {
  HT
  TTC
}

enum BudgetTaxMode {
  HT
  TTC
}

model HealthCheck {
  id        String   @id @default(uuid())
  checkedAt DateTime @default(now())
}

model Client {
  id                         String                    @id @default(cuid())
  name                       String
  slug                       String                    @unique
  createdAt                  DateTime                  @default(now())
  updatedAt                  DateTime                  @updatedAt
  budgetAccountingEnabled    Boolean                   @default(false)
  taxDisplayMode            TaxDisplayMode           @default(HT)
  taxInputMode              TaxInputMode             @default(HT)
  defaultTaxRate            Decimal?                  @db.Decimal(5, 2)
  clientUsers                ClientUser[]
  clientModules              ClientModule[]
  roles                      Role[]
  auditLogs                  AuditLog[]
  budgetExercises            BudgetExercise[]
  budgets                    Budget[]
  budgetEnvelopes            BudgetEnvelope[]
  budgetLines                BudgetLine[]
  financialAllocations       FinancialAllocation[]
  financialEvents            FinancialEvent[]
  suppliers                  Supplier[]
  purchaseOrders             PurchaseOrder[]
  invoices                   Invoice[]
  budgetSnapshots            BudgetSnapshot[]
  budgetReallocations        BudgetReallocation[]
  budgetImportMappings       BudgetImportMapping[]
  budgetImportJobs           BudgetImportJob[]
  budgetImportRowLinks       BudgetImportRowLink[]
  budgetVersionSets          BudgetVersionSet[]
  generalLedgerAccounts      GeneralLedgerAccount[]
  analyticalLedgerAccounts   AnalyticalLedgerAccount[]
  costCenters                CostCenter[]
  budgetLineCostCenterSplits BudgetLineCostCenterSplit[]
  projects         Project[]
  projectTasks     ProjectTask[]
  projectRisks     ProjectRisk[]
  projectMilestones ProjectMilestone[]
}

model User {
  id            String         @id @default(cuid())
  email         String         @unique
  passwordHash  String
  firstName     String?
  lastName      String?
  platformRole  PlatformRole?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  clientUsers   ClientUser[]
  userRoles     UserRole[]
  refreshTokens RefreshToken[]
  auditLogs     AuditLog[]
  securityLogs  SecurityLog[]
  ownedBudgets Budget[]           @relation("OwnedBudgets")
  createdBudgetSnapshots BudgetSnapshot[]
  budgetReallocationsCreated BudgetReallocation[]
  createdBudgetImportMappings BudgetImportMapping[]
  createdBudgetImportJobs    BudgetImportJob[]
  sponsoredProjects          Project[]           @relation("ProjectSponsor")
  ownedProjects              Project[]           @relation("ProjectOwner")
  assignedProjectTasks       ProjectTask[]
  ownedProjectRisks          ProjectRisk[]
}

model ClientUser {
  id        String           @id @default(cuid())
  userId    String
  clientId  String
  role      ClientUserRole
  status    ClientUserStatus @default(ACTIVE)
  isDefault Boolean          @default(false)
  createdAt DateTime         @default(now())
  updatedAt DateTime         @updatedAt
  user      User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@unique([userId, clientId])
  @@index([clientId])
  @@index([userId])
}

/// Catalogue global des modules (budgets, projects, contracts, etc.).
model Module {
  id            String         @id @default(cuid())
  code          String         @unique
  name          String
  description   String?
  isActive      Boolean        @default(true)
  permissions   Permission[]
  clientModules ClientModule[]
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
}

/// Activation d'un module pour un client donné.
model ClientModule {
  id        String             @id @default(cuid())
  clientId  String
  moduleId  String
  status    ClientModuleStatus @default(ENABLED)
  client    Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  module    Module             @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  createdAt DateTime           @default(now())
  updatedAt DateTime           @updatedAt

  @@unique([clientId, moduleId])
  @@index([clientId])
  @@index([moduleId])
}

/// Rôle métier client (scopé par client).
model Role {
  id             String          @id @default(cuid())
  clientId       String
  name           String
  description    String?
  isSystem       Boolean         @default(false)
  client         Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  rolePermissions RolePermission[]
  userRoles      UserRole[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@unique([clientId, name])
  @@index([clientId])
}

/// Permission unitaire globale (<module>.<action>).
model Permission {
  id             String          @id @default(cuid())
  code           String          @unique
  label          String
  description    String?
  moduleId       String
  module         Module          @relation(fields: [moduleId], references: [id], onDelete: Restrict)
  rolePermissions RolePermission[]
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt

  @@index([moduleId])
}

/// Liaison N:N rôle ↔ permission.
model RolePermission {
  id           String      @id @default(cuid())
  roleId       String
  permissionId String
  role         Role       @relation(fields: [roleId], references: [id], onDelete: Cascade)
  permission   Permission @relation(fields: [permissionId], references: [id], onDelete: Cascade)

  @@unique([roleId, permissionId])
}

/// Liaison utilisateur ↔ rôle métier (le client est porté par Role.clientId).
model UserRole {
  id        String   @id @default(cuid())
  userId    String
  roleId    String
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  role      Role     @relation(fields: [roleId], references: [id], onDelete: Cascade)
  createdAt DateTime @default(now())

  @@unique([userId, roleId])
  @@index([userId])
  @@index([roleId])
}

enum ClientModuleStatus {
  ENABLED
  DISABLED
}

// --- Projects MVP (RFC-PROJ-001) ---

/** Projet structuré vs activité de suivi plus légère (même entité `Project` côté SI). */
enum ProjectKind {
  PROJECT
  ACTIVITY
}

enum ProjectType {
  TRANSFORMATION
  INFRASTRUCTURE
  APPLICATION
  CYBERSECURITY
  COMPLIANCE
  ORGANIZATION
  PROCUREMENT
  GOVERNANCE
}

enum ProjectStatus {
  DRAFT
  PLANNED
  IN_PROGRESS
  ON_HOLD
  COMPLETED
  CANCELLED
  ARCHIVED
}

enum ProjectPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectCriticality {
  LOW
  MEDIUM
  HIGH
}

enum ProjectTaskStatus {
  TODO
  IN_PROGRESS
  BLOCKED
  DONE
  CANCELLED
}

enum ProjectTaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ProjectRiskStatus {
  OPEN
  MITIGATED
  CLOSED
  ACCEPTED
}

enum ProjectRiskProbability {
  LOW
  MEDIUM
  HIGH
}

enum ProjectRiskImpact {
  LOW
  MEDIUM
  HIGH
}

enum ProjectMilestoneStatus {
  PLANNED
  REACHED
  DELAYED
  CANCELLED
}

model Project {
  id        String  @id @default(cuid())
  clientId  String
  name      String
  code      String
  description String?

  kind         ProjectKind @default(PROJECT)
  type         ProjectType
  status       ProjectStatus
  priority     ProjectPriority

  sponsorUserId String?
  ownerUserId   String?

  startDate      DateTime?
  targetEndDate  DateTime?
  actualEndDate  DateTime?

  criticality     ProjectCriticality
  progressPercent Int?

  targetBudgetAmount Decimal? @db.Decimal(18, 2)
  pilotNotes         String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  sponsor  User?  @relation("ProjectSponsor", fields: [sponsorUserId], references: [id], onDelete: SetNull)
  owner    User?  @relation("ProjectOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)

  tasks      ProjectTask[]
  risks      ProjectRisk[]
  milestones ProjectMilestone[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([clientId, status])
  @@index([clientId, kind])
  @@index([targetEndDate])
}

model ProjectTask {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  title       String
  description String?

  assigneeUserId String?

  status   ProjectTaskStatus
  priority ProjectTaskPriority

  dueDate      DateTime?
  completedAt  DateTime?
  sortOrder    Int      @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client   Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project  Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  assignee User?   @relation(fields: [assigneeUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

model ProjectRisk {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  title       String
  description String?

  probability ProjectRiskProbability
  impact      ProjectRiskImpact

  actionPlan   String?
  ownerUserId  String?

  status     ProjectRiskStatus
  reviewDate DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
  owner   User?   @relation(fields: [ownerUserId], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([projectId])
}

model ProjectMilestone {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  name       String
  targetDate DateTime
  actualDate DateTime?

  status ProjectMilestoneStatus

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([projectId])
}

// --- Budget MVP (RFC-015-1A) ---

enum BudgetExerciseStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

enum BudgetStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum BudgetEnvelopeStatus {
  DRAFT
  ACTIVE
  LOCKED
  ARCHIVED
}

enum BudgetEnvelopeType {
  RUN
  BUILD
  TRANSVERSE
}

enum BudgetLineStatus {
  DRAFT
  ACTIVE
  CLOSED
  ARCHIVED
}

// --- Budget Versioning (RFC-019) ---

enum BudgetVersionKind {
  BASELINE
  REVISION
}

enum BudgetVersionStatus {
  DRAFT
  ACTIVE
  SUPERSEDED
  ARCHIVED
}

enum ExpenseType {
  OPEX
  CAPEX
}

enum FinancialSourceType {
  PROJECT
  ACTIVITY
  SUPPLIER
  CONTRACT
  LICENSE
  ORDER
  TEAM_ASSIGNMENT
  APPLICATION
  ASSET
  MANUAL
  PURCHASE_ORDER
  INVOICE
}

enum SupplierStatus {
  ACTIVE
  INACTIVE
  ARCHIVED
}

enum PurchaseOrderStatus {
  DRAFT
  ISSUED
  APPROVED
  PARTIALLY_INVOICED
  FULLY_INVOICED
  CANCELLED
}

enum InvoiceStatus {
  RECEIVED
  VALIDATED
  PAID
  CANCELLED
}

enum AllocationType {
  PLANNED
  RESERVED
  COMMITTED
  CONSUMED
  FORECAST
  REALLOCATED
  CANCELLED
}

enum FinancialEventType {
  LINE_CREATED
  BUDGET_INITIALIZED
  ALLOCATION_ADDED
  ALLOCATION_UPDATED
  COMMITMENT_REGISTERED
  CONSUMPTION_REGISTERED
  FORECAST_UPDATED
  REALLOCATION_DONE
  CANCELLATION
  ADJUSTMENT
}

model BudgetExercise {
  id        String               @id @default(cuid())
  clientId  String
  name      String
  code      String
  startDate DateTime
  endDate   DateTime
  status    BudgetExerciseStatus @default(DRAFT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgets   Budget[]
  budgetSnapshots BudgetSnapshot[]
  budgetVersionSets BudgetVersionSet[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([status])
}

model BudgetVersionSet {
  id               String    @id @default(cuid())
  clientId         String
  exerciseId       String
  code            String
  name            String
  description     String?
  baselineBudgetId String?   @unique
  activeBudgetId   String?    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise        BudgetExercise  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  versions        Budget[]        @relation("VersionSetVersions")
  baselineBudget  Budget?         @relation("VersionSetBaseline", fields: [baselineBudgetId], references: [id], onDelete: SetNull)
  activeBudget    Budget?         @relation("VersionSetActive", fields: [activeBudgetId], references: [id], onDelete: SetNull)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([exerciseId])
}

model Budget {
  id            String       @id @default(cuid())
  clientId      String
  exerciseId    String
  name          String
  code          String
  description   String?
  currency      String
  status        BudgetStatus @default(DRAFT)
  taxMode       BudgetTaxMode @default(HT)
  defaultTaxRate Decimal?    @db.Decimal(5, 2)
  ownerUserId   String?
  versionSetId  String?
  versionNumber Int?
  versionLabel  String?
  versionKind   BudgetVersionKind?
  versionStatus BudgetVersionStatus?
  parentBudgetId String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  isVersioned   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise      BudgetExercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  owner         User?        @relation("OwnedBudgets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  versionSet    BudgetVersionSet? @relation("VersionSetVersions", fields: [versionSetId], references: [id], onDelete: SetNull)
  parentBudget  Budget?      @relation("BudgetVersionParent", fields: [parentBudgetId], references: [id], onDelete: SetNull)
  childVersions Budget[]     @relation("BudgetVersionParent")
  baselineForSet BudgetVersionSet? @relation("VersionSetBaseline")
  activeForSet   BudgetVersionSet? @relation("VersionSetActive")
  envelopes     BudgetEnvelope[]
  budgetLines   BudgetLine[]
  budgetSnapshots BudgetSnapshot[]
  budgetReallocations BudgetReallocation[]
  budgetImportJobs    BudgetImportJob[]

  @@unique([clientId, code])
  @@unique([versionSetId, versionNumber])
  @@index([clientId])
  @@index([exerciseId])
  @@index([status])
  @@index([clientId, versionSetId])
  @@index([clientId, versionStatus])
  @@index([clientId, versionKind])
}

model BudgetEnvelope {
  id          String             @id @default(cuid())
  clientId    String
  budgetId    String
  parentId    String?
  name        String
  code        String
  type        BudgetEnvelopeType
  description String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  status      BudgetEnvelopeStatus @default(ACTIVE)
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget      Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent      BudgetEnvelope?    @relation("EnvelopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BudgetEnvelope[]   @relation("EnvelopeHierarchy")
  budgetLines BudgetLine[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([parentId])
}

enum BudgetLineAllocationScope {
  ENTERPRISE
  ANALYTICAL
}

model GeneralLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model AnalyticalLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model CostCenter {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  splits      BudgetLineCostCenterSplit[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model BudgetLine {
  id                       String                     @id @default(cuid())
  clientId                 String
  budgetId                 String
  envelopeId               String
  code                     String
  name                     String
  description              String?
  expenseType              ExpenseType
  status                   BudgetLineStatus           @default(DRAFT)
  currency                 String
  taxRate                  Decimal?                   @db.Decimal(5, 2)
  initialAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  revisedAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  forecastAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  committedAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  consumedAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  remainingAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  generalLedgerAccountId   String?
  analyticalLedgerAccountId String?
  allocationScope          BudgetLineAllocationScope  @default(ENTERPRISE)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  client                   Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget                   Budget                    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  envelope                 BudgetEnvelope            @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  generalLedgerAccount     GeneralLedgerAccount?     @relation(fields: [generalLedgerAccountId], references: [id], onDelete: Restrict)
  analyticalLedgerAccount  AnalyticalLedgerAccount?  @relation(fields: [analyticalLedgerAccountId], references: [id], onDelete: SetNull)
  costCenterSplits         BudgetLineCostCenterSplit[]
  allocations               FinancialAllocation[]
  financialEvents           FinancialEvent[]
  purchaseOrders            PurchaseOrder[]
  invoices                  Invoice[]
  reallocationsAsSource     BudgetReallocation[]      @relation("ReallocationSource")
  reallocationsAsTarget     BudgetReallocation[]      @relation("ReallocationTarget")

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([envelopeId])
  @@index([status])
}

model BudgetLineCostCenterSplit {
  id           String   @id @default(cuid())
  clientId     String
  budgetLineId String
  costCenterId String
  percentage   Decimal  @db.Decimal(5, 2)
  createdAt    DateTime @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Restrict)

  @@unique([budgetLineId, costCenterId])
  @@index([budgetLineId])
  @@index([clientId, budgetLineId])
  @@index([clientId, costCenterId])
}

enum BudgetSnapshotStatus {
  ACTIVE
  ARCHIVED
}

model BudgetSnapshot {
  id                   String                @id @default(cuid())
  clientId             String
  budgetId             String
  exerciseId           String
  name                 String
  code                 String
  description          String?
  snapshotDate         DateTime
  status               BudgetSnapshotStatus   @default(ACTIVE)

  budgetName           String
  budgetCode           String?
  budgetCurrency       String
  budgetStatus         BudgetStatus

  totalInitialAmount   Decimal               @db.Decimal(18, 2)
  totalRevisedAmount   Decimal               @db.Decimal(18, 2)
  totalForecastAmount  Decimal               @db.Decimal(18, 2)
  totalCommittedAmount Decimal               @db.Decimal(18, 2)
  totalConsumedAmount  Decimal               @db.Decimal(18, 2)
  totalRemainingAmount Decimal               @db.Decimal(18, 2)

  createdByUserId      String?
  createdAt            DateTime              @default(now())

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budget                Budget                @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  exercise              BudgetExercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  createdByUser         User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                 BudgetSnapshotLine[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([exerciseId])
  @@index([snapshotDate])
  @@index([clientId, budgetId])
}

model BudgetSnapshotLine {
  id               String   @id @default(cuid())
  snapshotId       String
  clientId         String

  budgetLineId     String
  budgetId         String
  envelopeId       String?

  envelopeName     String?
  envelopeCode     String?
  envelopeType     BudgetEnvelopeType?

  lineCode         String
  lineName         String
  expenseType      ExpenseType
  currency         String
  lineStatus       BudgetLineStatus

  initialAmount    Decimal  @db.Decimal(18, 2)
  revisedAmount    Decimal  @db.Decimal(18, 2)
  forecastAmount   Decimal  @db.Decimal(18, 2)
  committedAmount  Decimal  @db.Decimal(18, 2)
  consumedAmount   Decimal  @db.Decimal(18, 2)
  remainingAmount  Decimal  @db.Decimal(18, 2)

  createdAt        DateTime @default(now())

  snapshot         BudgetSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([clientId])
  @@index([budgetLineId])
  @@index([budgetId])
  @@index([envelopeId])
}

model FinancialAllocation {
  id             String         @id @default(cuid())
  clientId       String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String
  allocationType AllocationType
  allocatedAmount Decimal       @db.Decimal(18, 2)
  currency      String
  effectiveDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([allocationType])
}

model FinancialEvent {
  id            String              @id @default(cuid())
  clientId      String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String?
  eventType     FinancialEventType
  amount        Decimal             @db.Decimal(18, 2)
  amountHt      Decimal             @db.Decimal(18, 2)
  taxRate       Decimal?            @db.Decimal(5, 2)
  taxAmount     Decimal?            @db.Decimal(18, 2)
  amountTtc     Decimal?            @db.Decimal(18, 2)
  currency      String
  eventDate     DateTime
  label         String
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine          @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([eventType])
  @@index([eventDate])
}

model BudgetReallocation {
  id            String    @id @default(cuid())
  clientId      String
  budgetId      String
  sourceLineId  String
  targetLineId  String
  amount        Decimal   @db.Decimal(18, 2)
  currency      String
  reason        String?
  createdById   String?
  createdAt     DateTime  @default(now())

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget        Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  sourceLine    BudgetLine @relation("ReallocationSource", fields: [sourceLineId], references: [id], onDelete: Restrict)
  targetLine    BudgetLine @relation("ReallocationTarget", fields: [targetLineId], references: [id], onDelete: Restrict)
  createdBy     User?     @relation(fields: [createdById], references: [id], onDelete: SetNull)

  @@index([clientId])
  @@index([budgetId])
  @@index([sourceLineId])
  @@index([targetLineId])
  @@index([createdAt])
}

model Supplier {
  id             String         @id @default(cuid())
  clientId       String
  name           String
  code           String?
  siret          String?
  vatNumber      String?
  status         SupplierStatus @default(ACTIVE)
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt
  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  purchaseOrders PurchaseOrder[]
  invoices       Invoice[]

  @@unique([clientId, name])
  @@index([clientId])
  @@index([clientId, name])
}

model PurchaseOrder {
  id           String              @id @default(cuid())
  clientId     String
  supplierId   String
  budgetLineId String?
  reference    String
  label        String
  amountHt     Decimal             @db.Decimal(18, 2)
  taxRate      Decimal?            @db.Decimal(5, 2)
  taxAmount    Decimal?            @db.Decimal(18, 2)
  amountTtc    Decimal?            @db.Decimal(18, 2)
  orderDate    DateTime
  status       PurchaseOrderStatus @default(APPROVED)
  createdAt    DateTime            @default(now())
  updatedAt    DateTime            @updatedAt
  client       Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier     Supplier            @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  budgetLine   BudgetLine?         @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  invoices     Invoice[]

  @@unique([clientId, reference])
  @@index([clientId])
  @@index([supplierId])
  @@index([budgetLineId])
  @@index([clientId, supplierId])
}

model Invoice {
  id              String        @id @default(cuid())
  clientId        String
  supplierId      String
  budgetLineId    String?
  purchaseOrderId String?
  invoiceNumber   String
  label           String
  amountHt        Decimal       @db.Decimal(18, 2)
  taxRate         Decimal?      @db.Decimal(5, 2)
  taxAmount       Decimal?      @db.Decimal(18, 2)
  amountTtc       Decimal?      @db.Decimal(18, 2)
  invoiceDate     DateTime
  status          InvoiceStatus @default(VALIDATED)
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt
  client          Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  supplier        Supplier      @relation(fields: [supplierId], references: [id], onDelete: Restrict)
  budgetLine      BudgetLine?   @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  purchaseOrder   PurchaseOrder? @relation(fields: [purchaseOrderId], references: [id], onDelete: SetNull)

  @@unique([clientId, invoiceNumber, supplierId])
  @@index([clientId])
  @@index([supplierId])
  @@index([budgetLineId])
  @@index([clientId, supplierId])
}

// --- Budget Import (RFC-018) ---

enum BudgetImportSourceType {
  CSV
  XLSX
}

enum BudgetImportEntityType {
  BUDGET_LINES
}

enum BudgetImportTargetEntityType {
  BUDGET_LINE
}

enum BudgetImportJobStatus {
  ANALYZED
  PREVIEWED
  RUNNING
  COMPLETED
  FAILED
}

enum BudgetImportMode {
  CREATE_ONLY
  UPSERT
  UPDATE_ONLY
}

model BudgetImportMapping {
  id              String                  @id @default(cuid())
  clientId        String
  name            String
  description     String?
  sourceType      BudgetImportSourceType
  entityType      BudgetImportEntityType   @default(BUDGET_LINES)
  sheetName       String?
  headerRowIndex  Int                      @default(1)
  mappingConfig   Json
  optionsConfig   Json?
  createdById     String?
  createdAt       DateTime                @default(now())
  updatedAt       DateTime                @updatedAt

  client    Client   @relation(fields: [clientId], references: [id], onDelete: Cascade)
  createdBy User?   @relation(fields: [createdById], references: [id], onDelete: SetNull)
  jobs      BudgetImportJob[]

  @@index([clientId])
}

model BudgetImportJob {
  id            String                @id @default(cuid())
  clientId      String
  budgetId      String
  mappingId     String?
  fileName      String
  sourceType    BudgetImportSourceType
  status        BudgetImportJobStatus
  importMode    BudgetImportMode
  totalRows     Int                   @default(0)
  createdRows   Int                   @default(0)
  updatedRows   Int                   @default(0)
  skippedRows   Int                   @default(0)
  errorRows     Int                   @default(0)
  summary       Json?
  createdById   String?
  createdAt     DateTime              @default(now())

  client    Client                 @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget    Budget                 @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  mapping   BudgetImportMapping?   @relation(fields: [mappingId], references: [id], onDelete: SetNull)
  createdBy User?                  @relation(fields: [createdById], references: [id], onDelete: SetNull)
  rowLinks  BudgetImportRowLink[]

  @@index([clientId, budgetId])
  @@index([mappingId])
}

model BudgetImportRowLink {
  id               String                       @id @default(cuid())
  clientId         String
  budgetId         String
  importJobId      String
  targetEntityType BudgetImportTargetEntityType @default(BUDGET_LINE)
  targetEntityId   String
  sourceRowNumber  Int?
  externalId       String?
  compositeHash    String?
  fingerprintData  Json?
  createdAt        DateTime                    @default(now())

  client    Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  importJob BudgetImportJob  @relation(fields: [importJobId], references: [id], onDelete: Cascade)

  @@index([clientId, budgetId, targetEntityType, targetEntityId])
  @@index([clientId, budgetId, externalId])
  @@index([clientId, budgetId, compositeHash])
}

// --- End Budget MVP ---

model RefreshToken {
  id        String   @id @default(uuid())
  tokenHash String
  userId    String
  expiresAt DateTime
  createdAt DateTime @default(now())
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
}

model AuditLog {
  id String @id @default(cuid())

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user   User?  @relation(fields: [userId], references: [id], onDelete: SetNull)
  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
}

model AuditLogArchive {
  id String @id

  clientId String
  userId   String?

  action String

  resourceType String
  resourceId   String?

  oldValue Json?
  newValue Json?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt  DateTime
  archivedAt DateTime @default(now())

  @@index([clientId])
  @@index([userId])
  @@index([action])
  @@index([createdAt])
  @@index([resourceType])
}

model SecurityLog {
  id String @id @default(cuid())

  event String

  userId String?
  email  String?

  success Boolean
  reason  String?

  ipAddress String?
  userAgent String?
  requestId String?

  createdAt DateTime @default(now())

  user User? @relation(fields: [userId], references: [id])

  @@index([event])
  @@index([userId])
  @@index([createdAt])
}
