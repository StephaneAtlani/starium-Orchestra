  facilitator User?   @relation("ProjectReviewFacilitator", fields: [facilitatorUserId], references: [id], onDelete: SetNull)
  finalizedBy User?   @relation("ProjectReviewFinalizedBy", fields: [finalizedByUserId], references: [id], onDelete: SetNull)

  participants ProjectReviewParticipant[]
  decisions    ProjectReviewDecision[]
  actionItems  ProjectReviewActionItem[]

  @@index([clientId, projectId, reviewDate])
  @@index([clientId, projectId, status])
  @@index([projectId, reviewDate])
}

