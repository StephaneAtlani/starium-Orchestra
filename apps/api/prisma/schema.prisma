model BudgetExercise {
  id                        String                  @id @default(cuid())
  clientId                  String
  name                      String
  code                      String
  startDate                 DateTime
  endDate                   DateTime
  status                    BudgetExerciseStatus    @default(DRAFT)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  client                    Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgets                   Budget[]
  budgetSnapshots           BudgetSnapshot[]
  budgetVersionSets         BudgetVersionSet[]
  dashboardConfigsAsDefault BudgetDashboardConfig[]
  deferredFromLines         BudgetLine[]            @relation("DeferredExerciseBudgetLines")
  deferredFromEnvelopes     BudgetEnvelope[]        @relation("DeferredExerciseBudgetEnvelopes")

  @@unique([clientId, code])
  @@index([clientId])
  @@index([status])
}

model BudgetVersionSet {
  id               String   @id @default(cuid())
  clientId         String
  exerciseId       String
  code             String
  name             String
  description      String?
  baselineBudgetId String?  @unique
  activeBudgetId   String?  @unique
  createdAt        DateTime @default(now())
  updatedAt        DateTime @updatedAt

  client         Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise       BudgetExercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  versions       Budget[]       @relation("VersionSetVersions")
  baselineBudget Budget?        @relation("VersionSetBaseline", fields: [baselineBudgetId], references: [id], onDelete: SetNull)
  activeBudget   Budget?        @relation("VersionSetActive", fields: [activeBudgetId], references: [id], onDelete: SetNull)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([exerciseId])
}

model Budget {
  id                        String                  @id @default(cuid())
  clientId                  String
  exerciseId                String
  name                      String
  code                      String
  description               String?
  /// Texte de recherche normalisé — RFC-CORE-SEARCH-001
  searchText                String? @db.Text
  currency                  String
  status                    BudgetStatus            @default(DRAFT)
  taxMode                   BudgetTaxMode           @default(HT)
  defaultTaxRate            Decimal?                @db.Decimal(5, 2)
  ownerUserId               String?
  /// RFC-ORG-003
  ownerOrgUnitId            String?
  /// RFC-ORG-004
  stewardResourceId         String?
  versionSetId              String?
  versionNumber             Int?
  versionLabel              String?
  versionKind               BudgetVersionKind?
  versionStatus             BudgetVersionStatus?
  parentBudgetId            String?
  activatedAt               DateTime?
  archivedAt                DateTime?
  isVersioned               Boolean                 @default(false)
  createdAt                 DateTime                @default(now())
  updatedAt                 DateTime                @updatedAt
  client                    Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise                  BudgetExercise          @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  owner                     User?                   @relation("OwnedBudgets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  ownerOrgUnit              OrgUnit?                @relation("OrgUnitOwnedBudget", fields: [ownerOrgUnitId], references: [id], onDelete: Restrict)
  steward                   Resource?               @relation("BudgetStewardResource", fields: [stewardResourceId], references: [id], onDelete: SetNull)
  versionSet                BudgetVersionSet?       @relation("VersionSetVersions", fields: [versionSetId], references: [id], onDelete: SetNull)
  parentBudget              Budget?                 @relation("BudgetVersionParent", fields: [parentBudgetId], references: [id], onDelete: SetNull)
  childVersions             Budget[]                @relation("BudgetVersionParent")
  baselineForSet            BudgetVersionSet?       @relation("VersionSetBaseline")
  activeForSet              BudgetVersionSet?       @relation("VersionSetActive")
  envelopes                 BudgetEnvelope[]
  budgetLines               BudgetLine[]
  budgetSnapshots           BudgetSnapshot[]
  budgetReallocations       BudgetReallocation[]
  budgetImportJobs          BudgetImportJob[]
  dashboardConfigsAsDefault BudgetDashboardConfig[]

  @@unique([clientId, code])
  @@unique([versionSetId, versionNumber])
  @@index([clientId])
  @@index([exerciseId])
  @@index([status])
  @@index([clientId, versionSetId])
  @@index([clientId, versionStatus])
  @@index([clientId, versionKind])
  @@index([clientId, ownerOrgUnitId])
  @@index([clientId, stewardResourceId])
}

/// Configuration cockpit budgétaire (RFC-022).
model BudgetDashboardConfig {
  id                String   @id @default(cuid())
  clientId          String
  name              String
  isDefault         Boolean  @default(false)
  defaultExerciseId String?
  defaultBudgetId   String?
  layoutConfig      Json     @default("{}")
  filtersConfig     Json?
  thresholdsConfig  Json?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  client          Client                  @relation(fields: [clientId], references: [id], onDelete: Cascade)
  defaultExercise BudgetExercise?         @relation(fields: [defaultExerciseId], references: [id], onDelete: SetNull)
  defaultBudget   Budget?                 @relation(fields: [defaultBudgetId], references: [id], onDelete: SetNull)
  widgets         BudgetDashboardWidget[]

  @@index([clientId])
}

enum BudgetDashboardWidgetType {
  KPI
  ALERT_LIST
  ENVELOPE_LIST
  LINE_LIST
  CHART
}

enum BudgetDashboardChartType {
  RUN_BUILD_BREAKDOWN
  CONSUMPTION_TREND
}

model BudgetDashboardWidget {
  id        String                    @id @default(cuid())
  clientId  String
  configId  String
  type      BudgetDashboardWidgetType
  title     String
  position  Int
  size      String                    @default("full")
  settings  Json?
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  client    Client                          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  config    BudgetDashboardConfig           @relation(fields: [configId], references: [id], onDelete: Cascade)
  overrides BudgetDashboardWidgetOverride[]

  @@unique([configId, position])
  @@index([clientId])
  @@index([clientId, configId])
}

/// Override utilisateur minimal pour le cockpit budget (MVP).
/// Source de vérité côté client : `BudgetDashboardConfig` + `BudgetDashboardWidget`.
/// Les overrides ne modifient que `isActive` / `position` (et `settings` est interdit en MVP si non null/non vide).
model BudgetDashboardWidgetOverride {
  id String @id @default(cuid())

  clientId String
  userId   String
  widgetId String

  isActive Boolean?
  position Int?
  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user   User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  widget BudgetDashboardWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId, widgetId])
  @@index([clientId])
  @@index([userId])
  @@index([widgetId])
}

model BudgetEnvelope {
  id                   String               @id @default(cuid())
  clientId             String
  budgetId             String
  parentId             String?
  name                 String
  code                 String
  type                 BudgetEnvelopeType
  description          String?
  sortOrder            Int                  @default(0)
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  status               BudgetEnvelopeStatus @default(ACTIVE)
  deferredToExerciseId String?
  deferredToExercise   BudgetExercise?      @relation("DeferredExerciseBudgetEnvelopes", fields: [deferredToExerciseId], references: [id], onDelete: SetNull)
  client               Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget               Budget               @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent               BudgetEnvelope?      @relation("EnvelopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children             BudgetEnvelope[]     @relation("EnvelopeHierarchy")
  budgetLines          BudgetLine[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([parentId])
  @@index([status])
  @@index([deferredToExerciseId])
}

enum BudgetLineAllocationScope {
  ENTERPRISE
  ANALYTICAL
}

enum BudgetLinePlanningMode {
  MANUAL
  ANNUAL_SPREAD
  QUARTERLY_SPREAD
  ONE_SHOT
  GROWTH
  CALCULATED
}

model GeneralLedgerAccount {
