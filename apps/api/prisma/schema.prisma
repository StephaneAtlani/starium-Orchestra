  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model CostCenter {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client Client                      @relation(fields: [clientId], references: [id], onDelete: Restrict)
  splits BudgetLineCostCenterSplit[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model BudgetLine {
  id                            String                         @id @default(cuid())
  clientId                      String
  budgetId                      String
  envelopeId                    String
  code                          String
  name                          String
  description                   String?
  expenseType                   ExpenseType
  status                        BudgetLineStatus               @default(DRAFT)
  currency                      String
  taxRate                       Decimal?                       @db.Decimal(5, 2)
  initialAmount                 Decimal                        @default(0) @db.Decimal(18, 2)
  forecastAmount                Decimal                        @default(0) @db.Decimal(18, 2)
  committedAmount               Decimal                        @default(0) @db.Decimal(18, 2)
  consumedAmount                Decimal                        @default(0) @db.Decimal(18, 2)
  remainingAmount               Decimal                        @default(0) @db.Decimal(18, 2)
  generalLedgerAccountId        String?
  analyticalLedgerAccountId     String?
  allocationScope               BudgetLineAllocationScope      @default(ENTERPRISE)
  planningMode                  BudgetLinePlanningMode?
  planningTotalAmount           Decimal?                       @db.Decimal(18, 2)
  /// RFC-ORG-003 — override unité propriétaire (null = hériter du budget)
  ownerOrgUnitId                String?
  /// RFC-ORG-004
  stewardResourceId             String?
  createdAt                     DateTime                       @default(now())
  updatedAt                     DateTime                       @updatedAt
  client                        Client                         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget                        Budget                         @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  ownerOrgUnit                  OrgUnit?                       @relation("OrgUnitOwnedBudgetLine", fields: [ownerOrgUnitId], references: [id], onDelete: Restrict)
  steward                       Resource?                      @relation("BudgetLineStewardResource", fields: [stewardResourceId], references: [id], onDelete: SetNull)
  envelope                      BudgetEnvelope                 @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  deferredToExerciseId          String?
  deferredToExercise            BudgetExercise?                @relation("DeferredExerciseBudgetLines", fields: [deferredToExerciseId], references: [id], onDelete: SetNull)
  generalLedgerAccount          GeneralLedgerAccount?          @relation(fields: [generalLedgerAccountId], references: [id], onDelete: Restrict)
  analyticalLedgerAccount       AnalyticalLedgerAccount?       @relation(fields: [analyticalLedgerAccountId], references: [id], onDelete: SetNull)
  costCenterSplits              BudgetLineCostCenterSplit[]
  allocations                   FinancialAllocation[]
  financialEvents               FinancialEvent[]
  purchaseOrders                PurchaseOrder[]
  invoices                      Invoice[]
  reallocationsAsSource         BudgetReallocation[]           @relation("ReallocationSource")
  reallocationsAsTarget         BudgetReallocation[]           @relation("ReallocationTarget")
  projectBudgetLinks            ProjectBudgetLink[]
  projectScenarioFinancialLines ProjectScenarioFinancialLine[]
  projectTasks                  ProjectTask[]
  projectActivities             ProjectActivity[]
  planningMonths                BudgetLinePlanningMonth[]
  planningScenarios             BudgetLinePlanningScenario[]

  @@unique([clientId, budgetId, code])
