/// RFC-PROJ-DOC-001 — registre des documents rattachés à un projet (métadonnées + gouvernance).
/// NB: pas d'upload/download binaire dans le MVP ; pas de logique Microsoft dans cette RFC.
model ProjectDocument {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  name             String
  originalFilename String?
  mimeType         String?
  extension        String?
  sizeBytes        Int?

  category    ProjectDocumentCategory    @default(GENERAL)
  status      ProjectDocumentStatus      @default(ACTIVE)
  storageType ProjectDocumentStorageType @default(STARIUM)

  storageKey  String?
  externalUrl String?

  description String?
  tags        Json?

  uploadedByUserId String?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
  archivedAt       DateTime?
  deletedAt        DateTime?

  client         Client                        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project        Project                       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  uploadedByUser User?                         @relation("ProjectDocumentUploadedBy", fields: [uploadedByUserId], references: [id], onDelete: SetNull)
  microsoftSync  ProjectDocumentMicrosoftSync?

  @@index([clientId])
  @@index([projectId])
  @@index([clientId, projectId])
  @@index([clientId, status])
  @@index([clientId, projectId, status])
  @@index([storageType])
}

model ProjectPortfolioCategory {
