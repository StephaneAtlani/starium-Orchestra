  clientId       String
  projectId      String
  budgetLineId   String
  allocationType ProjectBudgetAllocationType
  percentage     Decimal?                    @db.Decimal(5, 2)
  amount         Decimal?                    @db.Decimal(18, 2)
  createdAt      DateTime                    @default(now())

  client         Client                         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project        Project                        @relation(fields: [projectId], references: [id], onDelete: Cascade)
  budgetLine     BudgetLine                     @relation(fields: [budgetLineId], references: [id], onDelete: Restrict)
  financialLines ProjectScenarioFinancialLine[]

  @@unique([projectId, budgetLineId])
  @@index([clientId])
}

/// Buckets Kanban / Planner par projet (Starium ou miroir Microsoft selon `ProjectMicrosoftLink.useMicrosoftPlannerBuckets`).
model ProjectTaskBucket {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  name            String
  sortOrder       Int     @default(0)
  /// Renseigné quand le bucket provient d’un plan Planner (sync Microsoft).
  plannerBucketId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client  Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project Project       @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks   ProjectTask[]

  @@unique([projectId, plannerBucketId])
  @@index([clientId])
  @@index([projectId])
}

/// Regroupement fonctionnel des tâches d'un projet (phase non éditée depuis la barre Gantt).
model ProjectTaskPhase {
  id        String @id @default(cuid())
  clientId  String
  projectId String

  name      String
  sortOrder Int    @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client     Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  project    Project            @relation(fields: [projectId], references: [id], onDelete: Cascade)
  tasks      ProjectTask[]
  milestones ProjectMilestone[]

  @@unique([projectId, sortOrder])
  @@index([clientId, projectId])
  @@index([projectId, sortOrder])
}

/// RFC-PLA-001 — plan d’actions (agrégateur de `ProjectTask`)
model ActionPlan {
  id              String             @id @default(cuid())
  clientId        String
  title           String
  code            String
  description     String?
  status          ActionPlanStatus
  priority        ActionPlanPriority
  ownerUserId     String?
  startDate       DateTime?
  targetDate      DateTime?
  progressPercent Int                @default(0)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client        @relation(fields: [clientId], references: [id], onDelete: Cascade)
  owner  User?         @relation("ActionPlanOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  tasks  ProjectTask[]

  @@unique([clientId, code])
  @@index([clientId])
}

/// RFC-PROJ-011 — tâche projet planifiable (Gantt-ready) ; `projectId` optionnel (RFC-PLA-001).
model ProjectTask {
  id        String  @id @default(cuid())
  clientId  String
  projectId String?

  actionPlanId String?
  riskId       String?

  phaseId         String?
  dependsOnTaskId String?

  bucketId String?

  code        String?
  name        String
  description String?

  status   ProjectTaskStatus   @default(TODO)
  priority ProjectTaskPriority @default(MEDIUM)
  progress Int                 @default(0)

  plannedStartDate DateTime?
  plannedEndDate   DateTime?
  actualStartDate  DateTime?
  actualEndDate    DateTime?

  sortOrder Int @default(0)

  dependencyType ProjectTaskDependencyType?

  ownerUserId           String?
  /// Responsable métier (ressource humaine — RFC-RES-001) ; distinct de `ownerUserId` (compte Starium).
  responsibleResourceId String?
  budgetLineId          String?

  /// Charge estimée (heures) — pilotage plan / tâche.
  estimatedHours Float?
  /// Étiquettes libres (JSON string[]) — MVP hors étiquettes projet.
  tags           Json?

  createdByUserId String?
  updatedByUserId String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client              Client             @relation(fields: [clientId], references: [id], onDelete: Restrict)
  project             Project?           @relation(fields: [projectId], references: [id], onDelete: SetNull)
  actionPlan          ActionPlan?        @relation(fields: [actionPlanId], references: [id], onDelete: SetNull)
  risk                ProjectRisk?       @relation(fields: [riskId], references: [id], onDelete: SetNull)
  budgetLine          BudgetLine?        @relation(fields: [budgetLineId], references: [id], onDelete: SetNull)
  bucket              ProjectTaskBucket? @relation(fields: [bucketId], references: [id], onDelete: SetNull)
  phase               ProjectTaskPhase?  @relation(fields: [phaseId], references: [id], onDelete: SetNull)
  responsibleResource Resource?          @relation("ProjectTaskResponsibleResource", fields: [responsibleResourceId], references: [id], onDelete: SetNull)

  dependsOnTask  ProjectTask?  @relation("ProjectTaskDependency", fields: [dependsOnTaskId], references: [id], onDelete: SetNull)
  dependentTasks ProjectTask[] @relation("ProjectTaskDependency")

  ownerUser     User? @relation("ProjectTaskOwner", fields: [ownerUserId], references: [id], onDelete: SetNull)
  createdByUser User? @relation("ProjectTaskCreatedBy", fields: [createdByUserId], references: [id], onDelete: SetNull)
  updatedByUser User? @relation("ProjectTaskUpdatedBy", fields: [updatedByUserId], references: [id], onDelete: SetNull)

  activities               ProjectActivity[]
  milestones               ProjectMilestone[]
  projectReviewActionItems ProjectReviewActionItem[]

  microsoftTaskSync ProjectTaskMicrosoftSync?
  checklistItems    ProjectTaskChecklistItem[]
  labelAssignments  ProjectTaskLabelAssignment[]

  @@index([clientId])
  @@index([projectId])
  @@index([clientId, projectId])
  @@index([clientId, actionPlanId])
  @@index([clientId, riskId])
  @@index([actionPlanId])
  @@index([riskId])
  @@index([phaseId])
  @@index([projectId, phaseId, sortOrder])
  @@index([dependsOnTaskId])
  @@index([status])
  @@index([priority])
  @@index([plannedStartDate])
  @@index([plannedEndDate])
  @@index([bucketId])
  @@index([responsibleResourceId])
}

/// Sous-éléments type « liste de contrôle » (sync Microsoft Planner : plannerTaskDetails.checklist).
model ProjectTaskChecklistItem {
  id            String @id @default(cuid())
  clientId      String
  projectId     String
  projectTaskId String

