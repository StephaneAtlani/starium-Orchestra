model BudgetExercise {
  id        String               @id @default(cuid())
  clientId  String
  name      String
  code      String
  startDate DateTime
  endDate   DateTime
  status    BudgetExerciseStatus @default(DRAFT)
  createdAt DateTime             @default(now())
  updatedAt DateTime             @updatedAt
  client    Client               @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgets   Budget[]
  budgetSnapshots BudgetSnapshot[]
  budgetVersionSets BudgetVersionSet[]
  dashboardConfigsAsDefault BudgetDashboardConfig[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([status])
}

model BudgetVersionSet {
  id               String    @id @default(cuid())
  clientId         String
  exerciseId       String
  code            String
  name            String
  description     String?
  baselineBudgetId String?   @unique
  activeBudgetId   String?    @unique
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  client          Client          @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise        BudgetExercise  @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  versions        Budget[]        @relation("VersionSetVersions")
  baselineBudget  Budget?         @relation("VersionSetBaseline", fields: [baselineBudgetId], references: [id], onDelete: SetNull)
  activeBudget    Budget?         @relation("VersionSetActive", fields: [activeBudgetId], references: [id], onDelete: SetNull)

  @@unique([clientId, code])
  @@index([clientId])
  @@index([exerciseId])
}

model Budget {
  id            String       @id @default(cuid())
  clientId      String
  exerciseId    String
  name          String
  code          String
  description   String?
  currency      String
  status        BudgetStatus @default(DRAFT)
  taxMode       BudgetTaxMode @default(HT)
  defaultTaxRate Decimal?    @db.Decimal(5, 2)
  ownerUserId   String?
  versionSetId  String?
  versionNumber Int?
  versionLabel  String?
  versionKind   BudgetVersionKind?
  versionStatus BudgetVersionStatus?
  parentBudgetId String?
  activatedAt   DateTime?
  archivedAt    DateTime?
  isVersioned   Boolean      @default(false)
  createdAt     DateTime     @default(now())
  updatedAt     DateTime     @updatedAt
  client        Client       @relation(fields: [clientId], references: [id], onDelete: Cascade)
  exercise      BudgetExercise @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  owner         User?        @relation("OwnedBudgets", fields: [ownerUserId], references: [id], onDelete: SetNull)
  versionSet    BudgetVersionSet? @relation("VersionSetVersions", fields: [versionSetId], references: [id], onDelete: SetNull)
  parentBudget  Budget?      @relation("BudgetVersionParent", fields: [parentBudgetId], references: [id], onDelete: SetNull)
  childVersions Budget[]     @relation("BudgetVersionParent")
  baselineForSet BudgetVersionSet? @relation("VersionSetBaseline")
  activeForSet   BudgetVersionSet? @relation("VersionSetActive")
  envelopes     BudgetEnvelope[]
  budgetLines   BudgetLine[]
  budgetSnapshots BudgetSnapshot[]
  budgetReallocations BudgetReallocation[]
  budgetImportJobs    BudgetImportJob[]
  dashboardConfigsAsDefault BudgetDashboardConfig[]

  @@unique([clientId, code])
  @@unique([versionSetId, versionNumber])
  @@index([clientId])
  @@index([exerciseId])
  @@index([status])
  @@index([clientId, versionSetId])
  @@index([clientId, versionStatus])
  @@index([clientId, versionKind])
}

/// Configuration cockpit budgétaire (RFC-022).
model BudgetDashboardConfig {
  id                  String   @id @default(cuid())
  clientId            String
  name                String
  isDefault           Boolean  @default(false)
  defaultExerciseId   String?
  defaultBudgetId     String?
  layoutConfig        Json     @default("{}")
  filtersConfig       Json?
  thresholdsConfig    Json?
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  client          Client           @relation(fields: [clientId], references: [id], onDelete: Cascade)
  defaultExercise BudgetExercise?  @relation(fields: [defaultExerciseId], references: [id], onDelete: SetNull)
  defaultBudget   Budget?          @relation(fields: [defaultBudgetId], references: [id], onDelete: SetNull)
  widgets         BudgetDashboardWidget[]

  @@index([clientId])
}

enum BudgetDashboardWidgetType {
  KPI
  ALERT_LIST
  ENVELOPE_LIST
  LINE_LIST
  CHART
}

enum BudgetDashboardChartType {
  RUN_BUILD_BREAKDOWN
  CONSUMPTION_TREND
}

model BudgetDashboardWidget {
  id        String                    @id @default(cuid())
  clientId  String
  configId  String
  type      BudgetDashboardWidgetType
  title     String
  position  Int
  size      String                    @default("full")
  settings  Json?
  isActive  Boolean                   @default(true)
  createdAt DateTime                  @default(now())
  updatedAt DateTime                  @updatedAt

  client Client                @relation(fields: [clientId], references: [id], onDelete: Cascade)
  config BudgetDashboardConfig @relation(fields: [configId], references: [id], onDelete: Cascade)
  overrides BudgetDashboardWidgetOverride[]

  @@unique([configId, position])
  @@index([clientId])
  @@index([clientId, configId])
}

/// Override utilisateur minimal pour le cockpit budget (MVP).
/// Source de vérité côté client : `BudgetDashboardConfig` + `BudgetDashboardWidget`.
/// Les overrides ne modifient que `isActive` / `position` (et `settings` est interdit en MVP si non null/non vide).
model BudgetDashboardWidgetOverride {
  id String @id @default(cuid())

  clientId String
  userId String
  widgetId String

  isActive Boolean?
  position Int?
  settings Json?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  client Client @relation(fields: [clientId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  widget BudgetDashboardWidget @relation(fields: [widgetId], references: [id], onDelete: Cascade)

  @@unique([clientId, userId, widgetId])
  @@index([clientId])
  @@index([userId])
  @@index([widgetId])
}

model BudgetEnvelope {
  id          String             @id @default(cuid())
  clientId    String
  budgetId    String
  parentId    String?
  name        String
  code        String
  type        BudgetEnvelopeType
  description String?
  sortOrder   Int                @default(0)
  createdAt   DateTime           @default(now())
  updatedAt   DateTime           @updatedAt
  status      BudgetEnvelopeStatus @default(ACTIVE)
  client      Client             @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget      Budget             @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  parent      BudgetEnvelope?    @relation("EnvelopeHierarchy", fields: [parentId], references: [id], onDelete: SetNull)
  children    BudgetEnvelope[]   @relation("EnvelopeHierarchy")
  budgetLines BudgetLine[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([parentId])
  @@index([status])
}

enum BudgetLineAllocationScope {
  ENTERPRISE
  ANALYTICAL
}

enum BudgetLinePlanningMode {
  MANUAL
  ANNUAL_SPREAD
  QUARTERLY_SPREAD
  ONE_SHOT
  GROWTH
  CALCULATED
}

model GeneralLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model AnalyticalLedgerAccount {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client       @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLines BudgetLine[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model CostCenter {
  id          String   @id @default(cuid())
  clientId    String
  code        String
  name        String
  description String?
  isActive    Boolean  @default(true)
  sortOrder   Int      @default(0)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  client      Client   @relation(fields: [clientId], references: [id], onDelete: Restrict)
  splits      BudgetLineCostCenterSplit[]

  @@unique([clientId, code])
  @@index([clientId, isActive])
}

model BudgetLine {
  id                       String                     @id @default(cuid())
  clientId                 String
  budgetId                 String
  envelopeId               String
  code                     String
  name                     String
  description              String?
  expenseType              ExpenseType
  status                   BudgetLineStatus           @default(DRAFT)
  currency                 String
  taxRate                  Decimal?                   @db.Decimal(5, 2)
  initialAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  revisedAmount            Decimal                    @db.Decimal(18, 2) @default(0)
  forecastAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  committedAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  consumedAmount           Decimal                    @db.Decimal(18, 2) @default(0)
  remainingAmount          Decimal                    @db.Decimal(18, 2) @default(0)
  generalLedgerAccountId   String?
  analyticalLedgerAccountId String?
  allocationScope          BudgetLineAllocationScope  @default(ENTERPRISE)
  planningMode             BudgetLinePlanningMode?
  planningTotalAmount      Decimal?                   @db.Decimal(18, 2)
  createdAt                DateTime                  @default(now())
  updatedAt                DateTime                  @updatedAt
  client                   Client                    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget                   Budget                    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
  envelope                 BudgetEnvelope            @relation(fields: [envelopeId], references: [id], onDelete: Restrict)
  generalLedgerAccount     GeneralLedgerAccount?     @relation(fields: [generalLedgerAccountId], references: [id], onDelete: Restrict)
  analyticalLedgerAccount  AnalyticalLedgerAccount?  @relation(fields: [analyticalLedgerAccountId], references: [id], onDelete: SetNull)
  costCenterSplits         BudgetLineCostCenterSplit[]
  allocations               FinancialAllocation[]
  financialEvents           FinancialEvent[]
  purchaseOrders            PurchaseOrder[]
  invoices                  Invoice[]
  reallocationsAsSource     BudgetReallocation[]      @relation("ReallocationSource")
  reallocationsAsTarget     BudgetReallocation[]      @relation("ReallocationTarget")
  projectBudgetLinks        ProjectBudgetLink[]
  projectTasks              ProjectTask[]
  projectActivities         ProjectActivity[]
  planningMonths            BudgetLinePlanningMonth[]
  planningScenarios         BudgetLinePlanningScenario[]

  @@unique([clientId, budgetId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([envelopeId])
  @@index([status])
}

model BudgetLinePlanningMonth {
  id           String   @id @default(cuid())
  clientId     String
  budgetLineId String
  monthIndex   Int
  amount       Decimal  @db.Decimal(18, 2)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine  BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@unique([budgetLineId, monthIndex])
  @@index([clientId, budgetLineId])
}

model BudgetLinePlanningScenario {
  id           String                 @id @default(cuid())
  clientId     String
  budgetLineId String
  mode         BudgetLinePlanningMode
  inputJson    Json
  createdById  String?
  createdAt    DateTime               @default(now())

  client      Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine  BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId, budgetLineId, createdAt])
}

model BudgetLineCostCenterSplit {
  id           String   @id @default(cuid())
  clientId     String
  budgetLineId String
  costCenterId String
  percentage   Decimal  @db.Decimal(5, 2)
  createdAt    DateTime @default(now())

  client     Client     @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budgetLine BudgetLine @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)
  costCenter CostCenter @relation(fields: [costCenterId], references: [id], onDelete: Restrict)

  @@unique([budgetLineId, costCenterId])
  @@index([budgetLineId])
  @@index([clientId, budgetLineId])
  @@index([clientId, costCenterId])
}

enum BudgetSnapshotStatus {
  ACTIVE
  ARCHIVED
}

model BudgetSnapshot {
  id                   String                @id @default(cuid())
  clientId             String
  budgetId             String
  exerciseId           String
  name                 String
  code                 String
  description          String?
  snapshotDate         DateTime
  status               BudgetSnapshotStatus   @default(ACTIVE)

  budgetName           String
  budgetCode           String?
  budgetCurrency       String
  budgetStatus         BudgetStatus

  totalInitialAmount   Decimal               @db.Decimal(18, 2)
  totalRevisedAmount   Decimal               @db.Decimal(18, 2)
  totalForecastAmount  Decimal               @db.Decimal(18, 2)
  totalCommittedAmount Decimal               @db.Decimal(18, 2)
  totalConsumedAmount  Decimal               @db.Decimal(18, 2)
  totalRemainingAmount Decimal               @db.Decimal(18, 2)

  createdByUserId      String?
  createdAt            DateTime              @default(now())

  client               Client                @relation(fields: [clientId], references: [id], onDelete: Restrict)
  budget                Budget                @relation(fields: [budgetId], references: [id], onDelete: Restrict)
  exercise              BudgetExercise        @relation(fields: [exerciseId], references: [id], onDelete: Restrict)
  createdByUser         User?                 @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  lines                 BudgetSnapshotLine[]

  @@unique([clientId, code])
  @@index([clientId])
  @@index([budgetId])
  @@index([exerciseId])
  @@index([snapshotDate])
  @@index([clientId, budgetId])
}

model BudgetSnapshotLine {
  id               String   @id @default(cuid())
  snapshotId       String
  clientId         String

  budgetLineId     String
  budgetId         String
  envelopeId       String?

  envelopeName     String?
  envelopeCode     String?
  envelopeType     BudgetEnvelopeType?

  lineCode         String
  lineName         String
  expenseType      ExpenseType
  currency         String
  lineStatus       BudgetLineStatus

  initialAmount    Decimal  @db.Decimal(18, 2)
  revisedAmount    Decimal  @db.Decimal(18, 2)
  forecastAmount   Decimal  @db.Decimal(18, 2)
  committedAmount  Decimal  @db.Decimal(18, 2)
  consumedAmount   Decimal  @db.Decimal(18, 2)
  remainingAmount  Decimal  @db.Decimal(18, 2)

  createdAt        DateTime @default(now())

  snapshot         BudgetSnapshot @relation(fields: [snapshotId], references: [id], onDelete: Cascade)

  @@index([snapshotId])
  @@index([clientId])
  @@index([budgetLineId])
  @@index([budgetId])
  @@index([envelopeId])
}

model FinancialAllocation {
  id             String         @id @default(cuid())
  clientId       String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String
  allocationType AllocationType
  allocatedAmount Decimal       @db.Decimal(18, 2)
  currency      String
  effectiveDate DateTime?
  notes         String?
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  client        Client         @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine     @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([allocationType])
}

model FinancialEvent {
  id            String              @id @default(cuid())
  clientId      String
  budgetLineId  String
  sourceType    FinancialSourceType
  sourceId      String?
  eventType     FinancialEventType
  amount        Decimal             @db.Decimal(18, 2)
  amountHt      Decimal             @db.Decimal(18, 2)
  taxRate       Decimal?            @db.Decimal(5, 2)
  taxAmount     Decimal?            @db.Decimal(18, 2)
  amountTtc     Decimal?            @db.Decimal(18, 2)
  currency      String
  eventDate     DateTime
  label         String
  description   String?
  createdAt     DateTime            @default(now())
  updatedAt     DateTime            @updatedAt
  client        Client              @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budgetLine    BudgetLine          @relation(fields: [budgetLineId], references: [id], onDelete: Cascade)

  @@index([clientId])
  @@index([budgetLineId])
  @@index([sourceType, sourceId])
  @@index([eventType])
  @@index([eventDate])
}

model BudgetReallocation {
  id            String    @id @default(cuid())
  clientId      String
  budgetId      String
  sourceLineId  String
  targetLineId  String
  amount        Decimal   @db.Decimal(18, 2)
  currency      String
  reason        String?
  createdById   String?
  createdAt     DateTime  @default(now())

  client        Client    @relation(fields: [clientId], references: [id], onDelete: Cascade)
  budget        Budget    @relation(fields: [budgetId], references: [id], onDelete: Cascade)
