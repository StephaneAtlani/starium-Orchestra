  children ProjectPortfolioCategory[] @relation("ProjectPortfolioCategoryTree")
  projects Project[]

  @@unique([clientId, parentId, normalizedName])
  @@index([clientId])
  @@index([clientId, parentId])
  @@index([clientId, isActive])
}

model ProjectTag {
