    "@types/qrcode": "^1.5.6",
    "@types/speakeasy": "^2.0.10",
    "eslint": "^9.17.0",
    "jest": "^30.2.0",
    "prisma": "^6.19.2",
    "ts-jest": "^29.4.7",
