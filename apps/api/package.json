    "revert:aravis": "node prisma/revert-aravis-import.js",
    "backfill:search-text": "ts-node --transpile-only scripts/backfill-search-text.ts",
    "verify:smtp": "ts-node --transpile-only scripts/verify-smtp.ts"
  },
  "prisma": {
    "seed": "ts-node prisma/seed.ts"
  },
