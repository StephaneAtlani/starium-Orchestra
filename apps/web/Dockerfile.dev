FROM node:20-alpine
RUN corepack enable && corepack prepare pnpm@9.14.2 --activate
WORKDIR /app
COPY . .
RUN pnpm install --frozen-lockfile || pnpm install
RUN pnpm --filter @starium-orchestra/types build
RUN pnpm --filter @starium-orchestra/rbac-permissions build
RUN pnpm --filter @starium-orchestra/budget-exercise-calendar build
# next dev (HMR) sur le port 3000 pour correspondre au mapping docker-compose
# Avec le volume mount ./apps/web:/app/apps/web, le node_modules du build est masqué :
# on réinstalle au démarrage pour que le montage ait bien ses deps.
RUN chmod +x /app/apps/web/docker-entrypoint-dev.sh
WORKDIR /app
EXPOSE 3000
CMD ["sh", "/app/apps/web/docker-entrypoint-dev.sh"]
